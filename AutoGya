local function getStandardNPC()
    local nearestnpc, nearest = nil, math.huge
    local pLevel = tonumber(player.PlayerFolder.Stats.Level.Value) or 0
    local npcSpawns = workspace:FindFirstChild("NPCSpawns")
    if not npcSpawns then return nil, false end

    local validBossExists = false

    for _, v in pairs(npcSpawns:GetChildren()) do
        local npc = v:IsA("Model") and v or v:FindFirstChildOfClass("Model")
        if npc and npc:FindFirstChild("Head") and not npc:FindFirstChild("AC") then
            
            local isTargetMob = (npc.Parent.Name == Config.FarmTarget)
            local isSpecificBoss = Config.Boss[npc.Name]
            
            local isBossMob = (MasterBossLevels[npc.Name] ~= nil) or (npc.Parent.Name == "NPCSpawns" and npc.Name ~= "Mob" and not TargetMap[npc.Name] and not string.find(npc.Name:lower(), "spawn"))

            if npc.Name == "Gyakusatsu" then
                -- ข้าม Gyakusatsu
            elseif Config.AllBossFarm and isBossMob then
                local req = MasterBossLevels[npc.Name] or 0
                if pLevel >= req then
                    validBossExists = true
                    local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
                end
            elseif isSpecificBoss and pLevel >= Config.BossLevels[npc.Name] then
                validBossExists = true
                local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
            elseif not Config.AllBossFarm and isTargetMob then
                local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
            end
        end
    end
    return nearestnpc, validBossExists
end

local function getFarmCFrame(npc, isBoss)
    local root = npc.HumanoidRootPart
    local dist = isBoss and Config.DistanceBoss or Config.DistanceNPC
    
    if Config.FarmPosition == "Above" then
        return CFrame.lookAt(root.Position + Vector3.new(0, dist, 0), root.Position)
    elseif Config.FarmPosition == "Bottom" then
        return CFrame.lookAt(root.Position + Vector3.new(0, -dist, 0), root.Position)
    elseif Config.FarmPosition == "Back" then
        local backPos = root.CFrame * CFrame.new(0, 0, dist)
        return CFrame.lookAt(backPos.Position, root.Position)
    end
    return root.CFrame
end

local function collectCorpse(npc)
    local timer = tick()
    local model = npc:WaitForChild(npc.Name.." Corpse", 2)
    if not model then return end
    local clickpart = model:WaitForChild("ClickPart", 2)
    if not clickpart then return end

    player.Character.HumanoidRootPart.CFrame = clickpart.CFrame * CFrame.new(0,1.7,0)
    repeat
        if tick() - timer > 4 then break end
        player.Character.Humanoid:MoveTo(clickpart.Position)
        task.wait()
        fireclickdetector(clickpart:FindFirstChildOfClass("ClickDetector") or clickpart[""], 1)
    until not model.Parent or not model.Parent.Parent or not Config.AutoFarm or player.Character.Humanoid.Health <= 0
end

