-- 6. Gyaku V13 Logic & Auto Hop
-- ==========================================
local function getGyakuTarget()
    local spawnFolder = workspace:FindFirstChild("NPCSpawns")
    if not spawnFolder then return nil, nil, false end
    local gyakuSpawn = spawnFolder:FindFirstChild("GyakusatsuSpawn")
    if not gyakuSpawn then return nil, nil, false end

    local hearts = {}
    local boss = nil

    for _, v in ipairs(gyakuSpawn:GetChildren()) do
        if v:IsA("Model") and v.Name ~= "Mob" then
            local hum = v:FindFirstChild("Humanoid")
            local hrp = v:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 then
                if v.Name == "Gyakusatsu" then boss = v else table.insert(hearts, v) end
            end
        end
    end

    local warpObj, aimPos, shouldLockCam
    if #hearts >= 2 then
        warpObj = hearts[1]; aimPos = hearts[2].HumanoidRootPart.Position; shouldLockCam = true
    elseif #hearts == 1 then
        warpObj = hearts[1]; aimPos = boss and boss.HumanoidRootPart.Position or warpObj.HumanoidRootPart.Position; shouldLockCam = false
    elseif boss then
        warpObj = boss; aimPos = boss.HumanoidRootPart.Position; shouldLockCam = false
    end
    return warpObj, aimPos, shouldLockCam
end

local isHopping = false
local function ServerHop()
    if isHopping then return end
    isHopping = true
    
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    pcall(function()
        local result = HttpService:JSONDecode(game:HttpGet(url))
        if result and result.data then
            for _, server in ipairs(result.data) do
                if server.playing > 0 and server.playing < server.maxPlayers - 2 and server.id ~= game.JobId then
                    
                    local qot = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
                    if qot and Config.AutoExecURL ~= "" then
                        qot(Config.AutoExecURL)
                    end

                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    task.wait(5)
                end
            end
        end
    end)
    task.wait(3); isHopping = false
end

