                            else
                                advanceIndex = advanceIndex + 1
                                char.Humanoid.AutoRotate = not Config.KajiriMode
                                char.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                                char.HumanoidRootPart.CFrame = CFrame.lookAt(standPos, nextAimPos)
                                triggerAttack(advMode, nextAimPos)
                            end
                        else
                            advanceIndex = advanceIndex + 1
                        end

                    -- [Orbit Boss Logic]
                    elseif bossObj and bossObj.Parent and bossObj.Humanoid.Health > 0 then
                        isTargetActive = true
                        local aimPos = bossObj.HumanoidRootPart.Position
                        local orbitTime = tick() * 1.5
                        local standPos = aimPos + Vector3.new(math.sin(orbitTime) * Config.GyakuDistance, 5, math.cos(orbitTime) * Config.GyakuDistance)
                        
                        local lookCFrame = CFrame.lookAt(standPos, aimPos)
                        tp(lookCFrame, aimPos, advMode, bossObj, 5) 
                        triggerAttack(advMode, aimPos)
                    end

                    -- [ระบบเช็คชัวร์ 10 วิ ก่อน Hop (Transition Validator)]
                    if isTargetActive then
                        gyakuHopWaitTick = 0 -- ถ้าตีบอสหรือหัวใจอยู่ รีเซ็ตเวลารอทิ้งไป
                    else
                        if char:FindFirstChild("Humanoid") then char.Humanoid.AutoRotate = true end
                        resetCamera()
                        if Config.HopBoss then 
                            if gyakuHopWaitTick == 0 then
                                gyakuHopWaitTick = tick() -- เริ่มนับถอยหลัง 10 วิ
                            elseif tick() - gyakuHopWaitTick > 1 then 
                                -- ถ้าผ่านไป 10 วิแล้วบอสไม่เกิด ค่อย Hop
                                ServerHop()
                                gyakuHopWaitTick = tick()
                            end
                        end
                    end

                else
                    Config.HasMasked = false; resetCamera() 
                    hasPressedHinamiF = false 
                    lastKajiriHold = 0
                end
            end)
        else
            Config.HasMasked = false; resetCamera() 
            hasPressedHinamiF = false
            lastKajiriHold = 0
            gyakuHopWaitTick = 0
        end
    end
end)

