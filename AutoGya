local function getStandardNPC()
    local nearestnpc, nearest = nil, math.huge
    local pLevel = tonumber(player.PlayerFolder.Stats.Level.Value) or 0
    local npcSpawns = workspace:FindFirstChild("NPCSpawns")
    if not npcSpawns then return nil, false, false end

    local validBossExists = false
    local targetBossFound = false
    local anySelectedBoss = false
    
    for name, isSelected in pairs(Config.Boss) do
        if isSelected then anySelectedBoss = true break end
    end

    local npcs = {}
    for _, v in pairs(npcSpawns:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            if v.Humanoid.Health > 0 and not v:FindFirstChild("AC") and v.Name ~= "Mob" then
                table.insert(npcs, v)
            end
        end
    end

    for _, npc in ipairs(npcs) do
        local npcName = npc.Name
        local isTargetMob = (npc.Parent and npc.Parent.Name == Config.FarmTarget)
        local isSpecificBoss = Config.Boss[npcName]
        local isBossMob = (MasterBossLevels[npcName] ~= nil) or (npc.Parent and npc.Parent.Name == "NPCSpawns" and not TargetMap[npcName] and not string.find(npcName:lower(), "spawn"))

        if string.find(npcName, "Gyakusatsu") then
            -- ข้าม Gyakusatsu
        elseif isSpecificBoss then
            validBossExists = true
            targetBossFound = true
            local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
        elseif Config.AllBossFarm and isBossMob then
            local req = MasterBossLevels[npcName] or 0
            if pLevel >= req then
                validBossExists = true
                if not Config.HopSelectedBoss then
                    local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                    if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
                end
            end
        elseif not Config.AllBossFarm and not Config.HopSelectedBoss and isTargetMob then
            local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if magnitude < nearest then nearestnpc, nearest = npc, magnitude end
        end
    end

    local shouldHop = false
    if Config.HopSelectedBoss and anySelectedBoss and not targetBossFound then
        shouldHop = true
    end

    return nearestnpc, validBossExists, shouldHop
end

local function getFarmCFrame(npc, isBoss)
    local root = npc.HumanoidRootPart
    local dist = isBoss and Config.DistanceBoss or Config.DistanceNPC
    if Config.FarmPosition == "Above" then return CFrame.lookAt(root.Position + Vector3.new(0, dist, 0), root.Position)
    elseif Config.FarmPosition == "Bottom" then return CFrame.lookAt(root.Position + Vector3.new(0, -dist, 0), root.Position)
    elseif Config.FarmPosition == "Back" then return CFrame.lookAt((root.CFrame * CFrame.new(0, 0, dist)).Position, root.Position) end
    return root.CFrame
end

local function collectCorpse(npc)
    local timer = tick()
    local model = npc:WaitForChild(npc.Name.." Corpse", 2)
    if not model then return end
    local clickpart = model:WaitForChild("ClickPart", 2)
    if not clickpart then return end

    player.Character.HumanoidRootPart.CFrame = clickpart.CFrame * CFrame.new(0,1.7,0)
    repeat
        if tick() - timer > 4 then break end
        player.Character.Humanoid:MoveTo(clickpart.Position)
        task.wait()
        fireclickdetector(clickpart:FindFirstChildOfClass("ClickDetector") or clickpart[""], 1)
    until not model.Parent or not model.Parent.Parent or not Config.AutoFarm or player.Character.Humanoid.Health <= 0
end

