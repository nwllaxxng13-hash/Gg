local function getGyakuTarget()
    local spawnFolder = workspace:FindFirstChild("NPCSpawns")
    if not spawnFolder then return nil, nil, false, nil, nil end
    local gyakuSpawn = spawnFolder:FindFirstChild("GyakusatsuSpawn")
    if not gyakuSpawn then return nil, nil, false, nil, nil end

    local hearts = {}
    local boss = nil

    for _, v in ipairs(gyakuSpawn:GetChildren()) do
        if v:IsA("Model") and v.Name ~= "Mob" then
            local hum = v:FindFirstChild("Humanoid")
            local hrp = v:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 then
                if v.Name == "Gyakusatsu" then boss = v else table.insert(hearts, v) end
            end
        end
    end

    if #hearts >= 2 then
        local cx, cz = 0, 0
        for _, h in ipairs(hearts) do
            cx = cx + h.HumanoidRootPart.Position.X
            cz = cz + h.HumanoidRootPart.Position.Z
        end
        cx = cx / #hearts
        cz = cz / #hearts

        table.sort(hearts, function(a, b)
            local angleA = math.atan2(a.HumanoidRootPart.Position.Z - cz, a.HumanoidRootPart.Position.X - cx)
            local angleB = math.atan2(b.HumanoidRootPart.Position.Z - cz, b.HumanoidRootPart.Position.X - cx)
            return angleA < angleB
        end)
    end

    local warpObj, aimPos, shouldLockCam
    if #hearts >= 2 then
        warpObj = hearts[1]; aimPos = hearts[2].HumanoidRootPart.Position; shouldLockCam = true
    elseif #hearts == 1 then
        warpObj = hearts[1]; aimPos = boss and boss.HumanoidRootPart.Position or warpObj.HumanoidRootPart.Position; shouldLockCam = false
    elseif boss then
        warpObj = boss; aimPos = boss.HumanoidRootPart.Position; shouldLockCam = false
    end
    return warpObj, aimPos, shouldLockCam, hearts, boss
end

