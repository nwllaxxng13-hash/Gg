local SaveFileName = "ArkHub_SavedConfig.json"

local function SaveConfig()
    pcall(function()
        if writefile then
            writefile(SaveFileName, HttpService:JSONEncode(Config))
        end
    end)
end

local function LoadConfig()
    pcall(function()
        if isfile and readfile and isfile(SaveFileName) then
            local data = HttpService:JSONDecode(readfile(SaveFileName))
            for k, v in pairs(data) do
                if type(v) == "table" and type(Config[k]) == "table" then
                    for subK, subV in pairs(v) do Config[k][subK] = subV end
                else
                    Config[k] = v
                end
            end
        end
    end)
end

