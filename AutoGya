local isHopping = false
local function ServerHop()
    if isHopping then return end
    isHopping = true
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    pcall(function()
        local result = HttpService:JSONDecode(game:HttpGet(url))
        if result and result.data then
            for _, server in ipairs(result.data) do
                if server.playing > 0 and server.playing < server.maxPlayers - 2 and server.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    task.wait(5)
                end
            end
        end
    end)
    task.wait(3); isHopping = false
end

local function pressKey(keyToPress, aimPosition)
    if not Config.Key or not player.Character or not player.Character:FindFirstChild("Remotes") then return end
    local hit = player:GetMouse().Hit
    local camCFrame = workspace.CurrentCamera.CFrame
    if aimPosition and player.Character:FindFirstChild("HumanoidRootPart") then
        hit = CFrame.new(aimPosition)
        camCFrame = CFrame.lookAt(player.Character.HumanoidRootPart.Position, aimPosition)
    end
    
    local fireEvent = Instance.new("RemoteEvent").FireServer
    fireEvent(player.Character.Remotes.KeyEvent, Config.Key, keyToPress, "Down", hit, nil, camCFrame)
    
    task.spawn(function()
        task.wait(0.1)
        pcall(function()
            fireEvent(player.Character.Remotes.KeyEvent, Config.Key, keyToPress, "Up", hit, nil, camCFrame)
        end)
    end)
end

local function resetCamera()
    if workspace.CurrentCamera.CameraType ~= Enum.CameraType.Custom then
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            workspace.CurrentCamera.CameraSubject = player.Character.Humanoid
        end
    end
end

local lastKajiriHold = 0
local gyakuSkillTick = 0

local function tp(targetCFrame, aimPos, advanceMode, targetObj, earlyStop)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = player.Character.HumanoidRootPart
    local val = Instance.new("CFrameValue")
    val.Value = hrp.CFrame
    
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local timeToTake = distance / Config.TweenSpeed
    if timeToTake < 0.1 then timeToTake = 0.1 end
    
    local tweenInfo = TweenInfo.new(timeToTake, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
    local tween = TweenService:Create(val, tweenInfo, {Value = targetCFrame})
    tween:Play()

    local completed = false
    tween.Completed:Connect(function() completed = true end)

    while not completed do
        if not (Config.AutoFarm or Config.GyakuFarm) or not player.Character or player.Character.Humanoid.Health <= 0 then 
            tween:Cancel() break 
        end
        
        if targetObj and (not targetObj.Parent or (targetObj:FindFirstChild("Humanoid") and targetObj.Humanoid.Health <= 0)) then
            tween:Cancel() break
        end
        
        if earlyStop and earlyStop > 0 then
            if (hrp.Position - targetCFrame.Position).Magnitude <= earlyStop then
                tween:Cancel()
                break
            end
        end

        if player.Character:FindFirstChild("HumanoidRootPart") then
            local currentHRP = player.Character.HumanoidRootPart
            currentHRP.CFrame = val.Value
            
            if aimPos then
                currentHRP.CFrame = CFrame.lookAt(val.Value.Position, aimPos)
            end

            currentHRP.Velocity = Vector3.new(0, 0, 0)
            currentHRP.RotVelocity = Vector3.new(0, 0, 0) 
            if player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.PlatformStand = false
            end
            
            if advanceMode == "Kajiri" and aimPos then
                if tick() - lastKajiriHold > 1.5 then
                    pressKey("F", aimPos)
                    lastKajiriHold = tick()
                end
            elseif advanceMode == "Kosshi" and aimPos then
                pressKey("E", aimPos); pressKey("R", aimPos); pressKey("F", aimPos); pressKey("C", aimPos)
            elseif advanceMode == "V3" and aimPos then
                pressKey("Mouse1", aimPos)
            elseif advanceMode == "Hinami" and aimPos then
                pressKey("E", aimPos)
            elseif advanceMode == "Scorpion" and aimPos then
                pressKey("Mouse1", aimPos)
            end
        end
        task.wait()
    end
    val:Destroy()
end

local function triggerAttack(mode, aimPos)
    if mode == "Kosshi" then
        pressKey("E", aimPos); pressKey("R", aimPos); pressKey("F", aimPos); pressKey("C", aimPos)
    elseif mode == "Scorpion" then
        if tick() - gyakuSkillTick > 2.5 then
            gyakuSkillTick = tick()
            task.spawn(function()
                pressKey("E", aimPos); task.wait(0.5)
                pressKey("R", aimPos); task.wait(0.5)
                pressKey("F", aimPos); task.wait(0.5)
                pressKey("C", aimPos); task.wait(0.5)
            end)
        end
        pressKey("Mouse1", aimPos)
    elseif mode == "V3" then
        pressKey("Mouse1", aimPos)
    elseif mode == "Hinami" then
        pressKey("E", aimPos)
    elseif mode == "Kajiri" then
        if tick() - lastKajiriHold > 3 then
            pressKey("F", aimPos)
            lastKajiriHold = tick()
        end
    else
        pressKey("Mouse1", aimPos)
    end
end

