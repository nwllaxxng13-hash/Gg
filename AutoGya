local SaveFileName = "GyakuFarm_SaveV13.json"

local function SaveConfig()
    pcall(function()
        if writefile then writefile(SaveFileName, HttpService:JSONEncode(Settings)) end
    end)
end

local function LoadConfig()
    pcall(function()
        if isfile and readfile and isfile(SaveFileName) then
            local data = HttpService:JSONDecode(readfile(SaveFileName))
            for k, v in pairs(data) do Settings[k] = v end
        end
    end)
end
