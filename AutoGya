                    local warpNpc, aimPos, shouldLockCam = getGyakuTarget()

                    if warpNpc and aimPos then
                        local standPos = warpNpc.HumanoidRootPart.Position + Vector3.new(0, Config.GyakuDistance, 0)
                        local distance = (char.HumanoidRootPart.Position - standPos).Magnitude

                        if distance > 25 then
                            local lookCFrame = CFrame.lookAt(standPos, aimPos)
                            tp(lookCFrame)
                        else
                            char.Humanoid.AutoRotate = not Config.KajiriMode
                            char.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                            char.HumanoidRootPart.CFrame = CFrame.lookAt(standPos, aimPos)
                            
                            if shouldLockCam then workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, aimPos) end

                            if Config.KajiriMode then
                                pressKey("F", aimPos); pressKey("Mouse1", aimPos)
                            else
                                pressKey("Mouse1", aimPos)
                            end
                        end
                    else
                        if char:FindFirstChild("Humanoid") then char.Humanoid.AutoRotate = true end
                        if Config.HopBoss then ServerHop() end
                    end
                else
                    Config.HasMasked = false
                end
            end)
        else
            Config.HasMasked = false
        end
    end
end)

