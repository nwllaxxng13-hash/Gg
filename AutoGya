local function pressKey(keyToPress, aimPosition)
    if not key or not player.Character or not player.Character:FindFirstChild("Remotes") then return end
    
    local hit = player:GetMouse().Hit
    local camCFrame = workspace.CurrentCamera.CFrame
    
    if aimPosition and player.Character:FindFirstChild("HumanoidRootPart") then
        hit = CFrame.new(aimPosition)
        camCFrame = CFrame.lookAt(player.Character.HumanoidRootPart.Position, aimPosition)
    end
    
    local fireEvent = Instance.new("RemoteEvent").FireServer
    fireEvent(player.Character.Remotes.KeyEvent, key, keyToPress, "Down", hit, nil, camCFrame)
end

-- [อัปเดต] หาระยะและเลือด + คืนค่าว่าควรล็อคกล้องหรือไม่ (shouldLockCam)
local function getSmartTarget()
    local spawnFolder = workspace:FindFirstChild("NPCSpawns")
    if not spawnFolder then return nil, nil, false end
    local gyakuSpawn = spawnFolder:FindFirstChild("GyakusatsuSpawn")
    if not gyakuSpawn then return nil, nil, false end

    local hearts = {}
    local boss = nil

    for _, v in ipairs(gyakuSpawn:GetChildren()) do
        if v:IsA("Model") and v.Name ~= "Mob" then
            local hum = v:FindFirstChild("Humanoid")
            local hrp = v:FindFirstChild("HumanoidRootPart")
            
            if hum and hrp and hum.Health > 0 then
                if v.Name == "Gyakusatsu" then
                    boss = v
                else
                    table.insert(hearts, v)
                end
            end
        end
    end

    local warpObj, aimPos, shouldLockCam

    if #hearts >= 2 then
        -- มี 2 ดวง: วาร์ปดวงแรก เล็งดวงสอง + ล็อคกล้อง
        warpObj = hearts[1]
        aimPos = hearts[2].HumanoidRootPart.Position
        shouldLockCam = true
    elseif #hearts == 1 then
        -- เหลือ 1 ดวง: วาร์ปหาดวงนั้น เล็งบอส + ปล่อยกล้องอิสระ
        warpObj = hearts[1]
        if boss then aimPos = boss.HumanoidRootPart.Position else aimPos = warpObj.HumanoidRootPart.Position end
        shouldLockCam = false
    elseif boss then
        -- เหลือแค่บอส: วาร์ปหาบอส เล็งบอส + ปล่อยกล้องอิสระ
        warpObj = boss
        aimPos = boss.HumanoidRootPart.Position
        shouldLockCam = false
    end

    return warpObj, aimPos, shouldLockCam
end

local isHopping = false
local function ServerHop()
    if isHopping then return end
    isHopping = true
    
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    pcall(function()
        local result = HttpService:JSONDecode(game:HttpGet(url))
        if result and result.data then
            for _, server in ipairs(result.data) do
                if server.playing > 0 and server.playing < server.maxPlayers - 2 and server.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    task.wait(5)
                end
            end
        end
    end)
    task.wait(3)
    isHopping = false
end

local function tp(targetCFrame)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = player.Character.HumanoidRootPart
    local val = Instance.new("CFrameValue")
    val.Value = hrp.CFrame
    
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local timeToTake = distance / Settings.TeleportSpeed
    if timeToTake < 0.1 then timeToTake = 0.1 end
    
    local tweenInfo = TweenInfo.new(timeToTake, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
    local tween = TweenService:Create(val, tweenInfo, {Value = targetCFrame})
    tween:Play()

    local completed = false
    tween.Completed:Connect(function() completed = true end)

    while not completed do
        if not Settings.AutoFarm or not player.Character or player.Character.Humanoid.Health <= 0 then 
            tween:Cancel() break 
        end
        if player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = val.Value
            player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        end
        task.wait()
    end
    val:Destroy()
end

-- ==========================================
-- 5. Main Auto Farm Loop
-- ==========================================
local hasMasked = false

task.spawn(function()
    task.wait(3)
    while task.wait() do
        if Settings.AutoFarm then
            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                    
                    -- [ใหม่] Auto Mask ตอนเกิด (ทำงานครั้งเดียวต่อ 1 ชีวิต)
                    if Settings.AutoMask and not hasMasked and key then
                        hasMasked = true
                        pcall(function()
                            local args = {
                                [1] = key, -- ใช้ Dynamic Key แทนค่าคงที่เพื่อความปลอดภัย
                                [2] = "M",
                                [3] = "Down",
                                [4] = "ShiftLock",
                            }
                            char.Remotes.KeyEvent:FireServer(unpack(args))
                        end)
                        task.wait(0.5)
                    end

                    if not char:FindFirstChild("Kagune") and not char:FindFirstChild("Quinque") then
                        pressKey(Settings.WeaponStage)
                        task.wait(0.5)
                    end

                    local warpNpc, aimPos, shouldLockCam = getSmartTarget()

                    if warpNpc and aimPos then
                        
                        local standPos = warpNpc.HumanoidRootPart.Position + Vector3.new(0, Settings.DistanceFromBoss, 0)
                        local distance = (char.HumanoidRootPart.Position - standPos).Magnitude

                        if distance > 25 then
                            local lookCFrame = CFrame.lookAt(standPos, aimPos)
                            tp(lookCFrame)
                        else
                            if Settings.NewKajiriMode then
                                char.Humanoid.AutoRotate = false
                            else
                                char.Humanoid.AutoRotate = true
                            end
                            
                            char.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                            char.HumanoidRootPart.CFrame = CFrame.lookAt(standPos, aimPos)
                            
                            -- [อัปเดต] ล็อคกล้องเฉพาะตอนมีหัวใจ >= 2 เท่านั้น
                            if shouldLockCam then
                                workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, aimPos)
                            end

                            if Settings.NewKajiriMode then
                                pressKey("F", aimPos)
                                pressKey("Mouse1", aimPos)
                            else
                                pressKey("Mouse1", aimPos)
                            end
                        end
                    else
                        if char:FindFirstChild("Humanoid") then
                            char.Humanoid.AutoRotate = true
                        end
                        if Settings.HopBoss then
                            ServerHop()
                        end
                    end
                else
                    -- รีเซ็ตสถานะหน้ากากเมื่อตาย
                    hasMasked = false
                end
            end)
        else
            -- รีเซ็ตสถานะหน้ากากเมื่อปิดฟาร์ม
            hasMasked = false
        end
    end
end)

