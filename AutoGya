        if Config.GyakuFarm then
            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                    
                    if Config.AutoMask and not Config.HasMasked and Config.Key then
                        Config.HasMasked = true
                        pcall(function() char.Remotes.KeyEvent:FireServer(Config.Key, "M", "Down", "ShiftLock") end)
                        task.wait(0.5)
                    end

                    if not char:FindFirstChild("Kagune") and not char:FindFirstChild("Quinque") then
                        pressKey(Config.WeaponStage)
                        task.wait(0.5)
