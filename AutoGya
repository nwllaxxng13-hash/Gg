-- ==========================================
local function needQuest()
    local qFolder = player.PlayerFolder:FindFirstChild("CurrentQuest")
    if not qFolder then return false end
    local comp = qFolder:FindFirstChild("Complete")
    if not comp then return true end
    
    for _, q in pairs(comp:GetChildren()) do
        if q:IsA("IntValue") or q:IsA("NumberValue") then
            local max = q:FindFirstChild("Max")
            if max and q.Value < max.Value then return false end
        end
    end
    return true
end

local function handleQuestAndCashout()
    local doQuest = Config.AutoTask and needQuest()
    local doCashout = Config.AutoCashOut and (tick() - oldCashoutTick > 7200)
    
    if not doQuest and not doCashout then return false end
    
    local team = player.PlayerFolder.Customization.Team.Value
    local npc = (team == "Ghoul") and workspace:FindFirstChild("Anteiku") and workspace.Anteiku:FindFirstChild("Yoshimura") or workspace:FindFirstChild("CCGBuilding") and workspace.CCGBuilding:FindFirstChild("Yoshitoki")
    
    if not npc or not npc:FindFirstChild("HumanoidRootPart") then return false end
    
    local targetCF = npc.HumanoidRootPart.CFrame
    local dist = (player.Character.HumanoidRootPart.Position - targetCF.Position).Magnitude
    
    if dist > 15 then
        tp(targetCF, nil, false, npc)
        return true
    else
        pcall(function()
            ReplicatedStorage.Remotes.Ally.AllyInfo:InvokeServer()
            if npc:FindFirstChild("TaskIndicator") and npc.TaskIndicator:FindFirstChild("ClickDetector") then
                fireclickdetector(npc.TaskIndicator.ClickDetector)
            end
            if doQuest then
                ReplicatedStorage.Remotes[npc.Name].Task:InvokeServer()
                task.wait(0.5)
                ReplicatedStorage.Remotes[npc.Name].Task:InvokeServer()
            end
            if doCashout then
                ReplicatedStorage.Remotes.ReputationCashOut:InvokeServer()
                oldCashoutTick = tick()
            end
        end)
        return true
    end
end

