local advanceIndex = 1

task.spawn(function()
    task.wait(3)
    while task.wait() do
        if Config.GyakuFarm then
            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                    
                    if Config.AutoMask and not Config.HasMasked and Config.Key then
                        Config.HasMasked = true
                        pcall(function() char.Remotes.KeyEvent:FireServer(Config.Key, "M", "Down", "ShiftLock") end)
                        task.wait(0.5)
                    end

                    if not char:FindFirstChild("Kagune") and not char:FindFirstChild("Quinque") then
                        pressKey(Config.WeaponStage)
                        task.wait(0.5)
                    end

                    local warpNpc, aimPos, shouldLockCam, heartsList, bossObj = getGyakuTarget()
                    local isMainBoss = (warpNpc and warpNpc.Name == "Gyakusatsu")

                    if warpNpc and aimPos then
                        
                        if Config.AdvanceKajiri and heartsList and #heartsList >= 2 and not isMainBoss then
                            if advanceIndex > #heartsList then advanceIndex = 1 end
                            
                            local targetHeart = heartsList[advanceIndex]
                            local nextIndex = (advanceIndex % #heartsList) + 1
                            local aimHeart = heartsList[nextIndex]
                            
                            local targetAimPos = aimHeart.HumanoidRootPart.Position
                            local standPos = targetHeart.HumanoidRootPart.Position + Vector3.new(0, Config.GyakuDistance, 0)
                            local dist = (char.HumanoidRootPart.Position - standPos).Magnitude
                            
                            if dist > 5 then
                                local lookCFrame = CFrame.lookAt(standPos, targetAimPos)
                                tp(lookCFrame, targetAimPos, true)
                            else
                                advanceIndex = nextIndex
                            end
                            
                        else
                            local standPos = warpNpc.HumanoidRootPart.Position + Vector3.new(0, Config.GyakuDistance, 0)
                            local distance = (char.HumanoidRootPart.Position - standPos).Magnitude

                            if distance > 25 then
                                local lookCFrame = CFrame.lookAt(standPos, aimPos)
                                tp(lookCFrame)
                            else
                                char.Humanoid.AutoRotate = not Config.KajiriMode
                                char.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                                char.HumanoidRootPart.CFrame = CFrame.lookAt(standPos, aimPos)
                                
                                if shouldLockCam then workspace.CurrentCamera.CFrame = CFrame.lookAt(workspace.CurrentCamera.CFrame.Position, aimPos) end

                                -- [อัปเดต] ถ้าเป็นบอสใหญ่ บังคับสแปมสกิล F อย่างเดียว (ไม่คลิกปกติ)
                                if isMainBoss then
                                    pressKey("F", aimPos)
                                elseif Config.KajiriMode then
                                    pressKey("F", aimPos); pressKey("Mouse1", aimPos)
                                else
                                    pressKey("Mouse1", aimPos)
                                end
                            end
                        end
                    else
                        if char:FindFirstChild("Humanoid") then char.Humanoid.AutoRotate = true end
                        if Config.HopBoss then ServerHop() end
                    end
                else
                    Config.HasMasked = false
                end
            end)
        else
            Config.HasMasked = false
        end
    end
end)

