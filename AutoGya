local function pressKey(keyToPress, aimPosition)
    if not Config.Key or not player.Character or not player.Character:FindFirstChild("Remotes") then return end
    
    local hit = player:GetMouse().Hit
    local camCFrame = workspace.CurrentCamera.CFrame
    
    if aimPosition and player.Character:FindFirstChild("HumanoidRootPart") then
        hit = CFrame.new(aimPosition)
        camCFrame = CFrame.lookAt(player.Character.HumanoidRootPart.Position, aimPosition)
    end
    
    local fireEvent = Instance.new("RemoteEvent").FireServer
    fireEvent(player.Character.Remotes.KeyEvent, Config.Key, keyToPress, "Down", hit, nil, camCFrame)
end

local function tp(targetCFrame)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = player.Character.HumanoidRootPart
    local val = Instance.new("CFrameValue")
    val.Value = hrp.CFrame
    
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local timeToTake = distance / Config.TweenSpeed
    if timeToTake < 0.1 then timeToTake = 0.1 end
    
    local tweenInfo = TweenInfo.new(timeToTake, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
    local tween = TweenService:Create(val, tweenInfo, {Value = targetCFrame})
    tween:Play()

    local completed = false
    tween.Completed:Connect(function() completed = true end)

    while not completed do
        if not (Config.AutoFarm or Config.GyakuFarm) or not player.Character or player.Character.Humanoid.Health <= 0 then 
            tween:Cancel() break 
        end
        if player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = val.Value
            player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        end
        task.wait()
    end
    val:Destroy()
end

-- ==========================================
-- 4. Standard Farm Logic (Template)
-- ==========================================
local function getStandardNPC()
    local nearestnpc, nearest = nil, math.huge
    local pLevel = tonumber(player.PlayerFolder.Stats.Level.Value) or 0

    local npcSpawns = workspace:FindFirstChild("NPCSpawns")
    if not npcSpawns then return nil end

    for _, v in pairs(npcSpawns:GetChildren()) do
        local npc = v:FindFirstChildOfClass("Model")
        if npc and npc:FindFirstChild("Head") and not npc:FindFirstChild("AC") then
            if npc.Parent.Name == Config.FarmTarget then
                local magnitude = (npc.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if magnitude < nearest then
                    nearestnpc, nearest = npc, magnitude
                end
            elseif Config.Boss[npc.Name] and pLevel >= Config.BossLevels[npc.Name] then
                return npc
            end
        end
    end
    return nearestnpc
end

local function collectCorpse(npc)
    local timer = tick()
    local model = npc:WaitForChild(npc.Name.." Corpse", 2)
    if not model then return end
    local clickpart = model:WaitForChild("ClickPart", 2)
    if not clickpart then return end

    player.Character.HumanoidRootPart.CFrame = clickpart.CFrame * CFrame.new(0,1.7,0)
    repeat
        if tick() - timer > 4 then break end
        player.Character.Humanoid:MoveTo(clickpart.Position)
        task.wait()
        fireclickdetector(clickpart:FindFirstChildOfClass("ClickDetector") or clickpart[""], 1)
    until not model.Parent or not model.Parent.Parent or not Config.AutoFarm or player.Character.Humanoid.Health <= 0
end

task.spawn(function()
    while task.wait() do
        if Config.AutoFarm and not Config.GyakuFarm then
            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                    
                    if not char:FindFirstChild("Kagune") and not char:FindFirstChild("Quinque") then
                        pressKey(Config.WeaponStage)
                        task.wait(0.5)
                    end

                    local npc = getStandardNPC()
                    if npc then
                        local isBoss = Config.Boss[npc.Name]
                        local targetCF
                        
                        if isBoss then
                            targetCF = npc.HumanoidRootPart.CFrame * CFrame.Angles(math.rad(90),0,0) + Vector3.new(0, Config.GyakuDistance, 0)
                        else
                            targetCF = npc.HumanoidRootPart.CFrame + npc.HumanoidRootPart.CFrame.lookVector * Config.DistanceFromNpc
                        end
                        
                        local dist = (char.HumanoidRootPart.Position - targetCF.Position).Magnitude
                        
                        if dist > 15 then
                            tp(targetCF)
                        else
                            char.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                            char.HumanoidRootPart.CFrame = targetCF
                            
                            if player.PlayerFolder.CanAct.Value then
                                pressKey("Mouse1")
                                if isBoss then
                                    for keyName, isEnabled in pairs(Config.Skills) do
                                        if isEnabled then pressKey(keyName) end
                                    end
                                end
                            end
                        end
                        
                        if npc.Humanoid.Health <= 0 and not isBoss then
                            collectCorpse(npc)
                        end
                    end
                end
            end)
        end
    end
end)

