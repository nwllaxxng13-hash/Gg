-- Hotkeys
-- ──────────────────────────────
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F7 then
        AutoPromptEnabled = not AutoPromptEnabled
        notify("Auto Prompt", AutoPromptEnabled and "ON" or "OFF", 1.2)
    end
    -- F8: Toggle Silent Aim เร็วๆ
    if input.KeyCode == Enum.KeyCode.F8 then
        SilentAimConfig.Enabled = not SilentAimConfig.Enabled
        if not SilentAimConfig.Enabled then sa_currentTarget = nil; SA_updateHighlight(nil) end
        notify("Silent Aim", SilentAimConfig.Enabled and "ON" or "OFF", 1.2)
    end
end)

