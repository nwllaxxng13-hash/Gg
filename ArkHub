-- Universal FE Gun Kit Fail-Safe Hook
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if SilentAim_Enabled and Method == "FireServer" and self.Name == "VisualizeBullet" then
        if SilentAim_CurrentTarget and SilentAim_CurrentTarget:FindFirstChild(SilentAim_TargetPart) then
            local TargetPart = SilentAim_CurrentTarget[SilentAim_TargetPart]
            
            for i, arg in pairs(Args) do
                if typeof(arg) == "table" then
                    for subIndex, subValue in pairs(arg) do
                        if typeof(subValue) == "Vector3" then
                            local MuzzlePos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or Vector3.new()
                            for _, potentialPart in pairs(Args) do
                                if typeof(potentialPart) == "Instance" and (potentialPart:IsA("BasePart") or potentialPart:IsA("Attachment")) then
                                    MuzzlePos = (potentialPart:IsA("Attachment") and potentialPart.WorldPosition) or potentialPart.Position
                                    break
                                end
                            end
                            -- Redirect bullet
                            arg[subIndex] = (TargetPart.Position - MuzzlePos).Unit
                        end
                        
                        -- Bypass Spread unless Shotgun mode is enabled (which syncs with Gun Buff spread naturally)
                        if not SilentAim_ShotgunMode then
                            if subIndex == "Spread" or subIndex == "Accuracy" or subIndex == "Recoil" then
                                arg[subIndex] = 0
                            end
                        end
                    end
                end
            end
            return OldNamecall(self, unpack(Args))
        end
    end
    return OldNamecall(self, ...)
end)

