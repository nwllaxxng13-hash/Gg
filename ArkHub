local function getAllTools()
    local tools = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                table.insert(tools, item.Name)
            end
        end
    end
    if character then
        for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Tool") then
                if not table.find(tools, item.Name) then table.insert(tools, item.Name) end
            end
        end
    end
    table.sort(tools)
    return tools
end

local function executeGunBuff()
    if not GunBuffConfig.SelectedGun then
        notify("Gun Buff", "กรุณาเลือกปืนก่อน!", 2)
        return false
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    local gun = nil
    
    if backpack then gun = backpack:FindFirstChild(GunBuffConfig.SelectedGun) end
    if not gun and character then gun = character:FindFirstChild(GunBuffConfig.SelectedGun) end
    if not gun then
        notify("Gun Buff", "ไม่พบปืน: " .. GunBuffConfig.SelectedGun, 2)
        updateGunBuffLabel(false)
        return false
    end
    
    local settingModule = gun:FindFirstChild("Setting")
    if not settingModule then notify("Gun Buff", "ไม่พบ Setting module", 2); updateGunBuffLabel(false); return false end
    local mainSetting = settingModule:FindFirstChild("1")
    if not mainSetting then notify("Gun Buff", "ไม่พบ Setting/1", 2); updateGunBuffLabel(false); return false end
    
    local success = pcall(function()
        local h = require(mainSetting)
        for key, value in pairs(GunBuffConfig.Settings) do
            if h[key] ~= nil then
                h[key] = value
            elseif key == "Lifesteal" or key == "LimitedAmmoEnabled" then
                h[key] = value
            end
        end
    end)
    
    if success then
        notify("Gun Buff", "บัฟปืนสำเร็จ! ✅", 1.5)
        updateGunBuffLabel(true)
        return true
    else
        notify("Gun Buff", "บัฟปืนล้มเหลว ❌", 2)
        updateGunBuffLabel(false)
        return false
    end
end

local function executeAudioBuff()
    if not GunBuffConfig.SelectedGun then return false end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    local gun = nil
    if backpack then gun = backpack:FindFirstChild(GunBuffConfig.SelectedGun) end
    if not gun and character then gun = character:FindFirstChild(GunBuffConfig.SelectedGun) end
    if not gun then return false end
    
    local settingModule = gun:FindFirstChild("Setting")
    if not settingModule then return false end
    local mainSetting = settingModule:FindFirstChild("1")
    if not mainSetting then return false end

    local success = pcall(function()
        local h = require(mainSetting)
        local tid = AudioConfig.TargetSoundID
        h.HitSoundIDs = { tid }; h.HitSoundVolume = AudioConfig.HitSoundVolume
        h.HitmarkerSoundID = { tid }; h.HitmarkerSoundPitch = AudioConfig.HitmarkerSoundPitch
        h.ExplosionSoundIDs = { tid }; h.ExplosionSoundVolume = AudioConfig.ExplosionSoundVolume
        h.WhizSoundID = { tid }; h.WhizSoundVolume = AudioConfig.WhizSoundVolume
        h.GoreSoundIDs = { tid }; h.GoreSoundVolume = AudioConfig.GoreSoundVolume
        h.MeleeHitSoundIDs = { tid }; h.MeleeHitCharSndIDs = { tid }; h.MeleeHitSoundVolume = AudioConfig.MeleeHitSoundVolume
        h.HitCharSndIDs = { tid }; h.HitCharSndVolume = AudioConfig.HitCharSndVolume
    end)
    if success then notify("Audio Buff", "ยัดเครื่องเสียงสำเร็จ! 🎵", 2); return true end
    return false
end

