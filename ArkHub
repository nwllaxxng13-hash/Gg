-- hookmetamethod - ดักจับ FireServer ของ VisualizeBullet
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args   = {...}

    if SilentAimConfig.Enabled and Method == "FireServer" and self.Name == "VisualizeBullet" then
        local Target = sa_currentTarget
        if Target and Target.Parent then
            for _, arg in pairs(Args) do
                if typeof(arg) == "table" then
                    -- หาจุดปากกระบอกปืน
                    local MuzzlePos = LocalPlayer.Character
                        and (LocalPlayer.Character:FindFirstChild("Head") or LocalPlayer.Character:FindFirstChild("HumanoidRootPart"))
                        and (LocalPlayer.Character:FindFirstChild("Head") or LocalPlayer.Character:FindFirstChild("HumanoidRootPart")).Position
                        or Vector3.new()
                    for _, potentialPart in pairs(Args) do
                        if typeof(potentialPart) == "Instance" and
                           (potentialPart:IsA("BasePart") or potentialPart:IsA("Attachment")) then
                            MuzzlePos = potentialPart:IsA("Attachment")
                                and potentialPart.WorldPosition
                                or potentialPart.Position
                            break
                        end
                    end

                    for subIndex, subValue in pairs(arg) do
                        -- เบนทิศกระสุนไปหาเป้า
                        if typeof(subValue) == "Vector3" then
                            arg[subIndex] = (Target.Position - MuzzlePos).Unit
                        end

                        -- Shotgun Mode: ใช้ค่าจาก GunBuff Tab, ปกติ: ลด Spread/Recoil = 0
                        if subIndex == "Spread" or subIndex == "Accuracy" then
                            arg[subIndex] = SilentAimConfig.ShotgunMode
                                and (GunBuffConfig.Settings.Spread or 0)
                                or 0
                        elseif subIndex == "Recoil" then
                            arg[subIndex] = SilentAimConfig.ShotgunMode
                                and (GunBuffConfig.Settings.Recoil or 0)
                                or 0
                        end
                    end
                end
            end
            return OldNamecall(self, unpack(Args))
        end
    end
    return OldNamecall(self, ...)
end)

