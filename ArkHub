local GunSelectSection = GunBuffTab:Section({ Title = "เลือกปืน" })
local currentGunDropdown = nil
GunSelectSection:Button({ Title = "🔄 Tool Refresh", Desc = "รีเฟรชรายการ Tool",
    Callback = function()
        local tools = getAllTools()
        if #tools == 0 then notify("Gun Buff", "ไม่พบ Tool ในตัว", 2); return end
        if currentGunDropdown then
            local success = pcall(function() currentGunDropdown:Refresh(tools, true) end)
            if not success then
                pcall(function() currentGunDropdown:SetValues(tools) end)
                pcall(function() currentGunDropdown:UpdateValues(tools) end)
            end
        end
        notify("Tool Refresh", "พบ " .. #tools .. " Tools", 1.5)
    end })
GunSelectSection:Space()
currentGunDropdown = GunSelectSection:Dropdown({ Title = "เลือกปืน", Values = getAllTools(), Value = nil, AllowNone = true, Multi = false,
    Callback = function(selected) GunBuffConfig.SelectedGun = selected; notify("Gun Selected", selected or "None", 1.2) end })

local GunStatsSection = GunBuffTab:Section({ Title = "ค่าสถิติปืน" })
local statInputs = {
    { key = "AmmoPerMag",           title = "AmmoPerMag",           default = 100 },
    { key = "MaxAmmo",              title = "MaxAmmo",              default = 20 },
    { key = "Recoil",               title = "Recoil",               default = 0.1 },
    { key = "Spread",               title = "Spread",               default = 20 },
    { key = "FireRate",             title = "FireRate",             default = 0.6 },
    { key = "BaseDamage",           title = "BaseDamage",           default = 20 },
    { key = "Ammo",                 title = "Ammo",                 default = 30 },
    { key = "Range",                title = "Range",                default = 99999 },
    { key = "ZeroDamageDistance",   title = "ZeroDamageDistance",   default = 99999 },
    { key = "FullDamageDistance",   title = "FullDamageDistance",   default = 1000 },
    { key = "ReloadTime",           title = "ReloadTime",           default = 0.1 },
    { key = "ExplosionRadius",      title = "ExplosionRadius",      default = "math.huge" },
    { key = "WhizDistance",         title = "WhizDistance",         default = 20 },
    { key = "HitSoundVolume",       title = "HitSoundVolume",       default = "math.huge" },
    { key = "BulletPerShot",        title = "BulletPerShot",        default = 12 },
    { key = "ExplosionSoundVolume", title = "ExplosionSoundVolume", default = "math.huge" },
    { key = "FriendlyFire",         title = "FriendlyFire",         default = true },
    { key = "GoreSoundVolume",      title = "GoreSoundVolume",      default = "math.huge" },
    { key = "GoreSoundIDs",         title = "GoreSoundIDs",         default = 19230359546 },
    { key = "LightBrightness",      title = "LightBrightness",      default = "math.huge" },
    { key = "LightRange",           title = "LightRange",           default = "math.huge" },
    { key = "Lifesteal",            title = "Lifesteal",            default = 0.1 },
    { key = "LimitedAmmoEnabled",   title = "LimitedAmmoEnabled",   default = false },
}
for i, stat in ipairs(statInputs) do
    GunStatsSection:Input({ Title = stat.title, Desc = "ค่า: " .. tostring(stat.default), Placeholder = tostring(stat.default),
        Callback = function(txt)
            if txt == "" then GunBuffConfig.Settings[stat.key] = stat.default; return end
            if txt == "math.huge" or txt == "inf" or txt == "infinite" then GunBuffConfig.Settings[stat.key] = math.huge; return end
            if txt == "true" then GunBuffConfig.Settings[stat.key] = true; return
            elseif txt == "false" then GunBuffConfig.Settings[stat.key] = false; return end
            local num = tonumber(txt)
            if num then GunBuffConfig.Settings[stat.key] = num
            else notify("Invalid Input", stat.title .. " ต้องเป็นตัวเลข", 2) end
        end })
    if i < #statInputs then GunStatsSection:Space() end
end

