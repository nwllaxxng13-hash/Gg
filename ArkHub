local CrashSection = CrashTab:Section({ Title = "⚠️ God Mode" })
CrashSection:Button({ Title = "💥 God Gun Buff", Desc = "Spread=999 | BulletPerShot=99999 | BaseDamage=999",
    Callback = function()
        if not GunBuffConfig.SelectedGun then notify("God Gun Buff", "กรุณาเลือกปืนใน Tab บัฟปืนก่อน!", 3); return end
        local backpack = LocalPlayer:FindFirstChild("Backpack"); local character = LocalPlayer.Character; local gun = nil
        if backpack then gun = backpack:FindFirstChild(GunBuffConfig.SelectedGun) end
        if not gun and character then gun = character:FindFirstChild(GunBuffConfig.SelectedGun) end
        if not gun then notify("God Gun Buff", "ไม่พบปืน: " .. GunBuffConfig.SelectedGun, 2); return end
        local settingModule = gun:FindFirstChild("Setting")
        if not settingModule then notify("God Gun Buff", "ไม่พบ Setting module", 2); return end
        local mainSetting = settingModule:FindFirstChild("1")
        if not mainSetting then notify("God Gun Buff", "ไม่พบ Setting/1", 2); return end
        local success = pcall(function()
            local h = require(mainSetting)
            h.Spread = 999; h.BulletPerShot = 99999; h.BaseDamage = 999
        end)
        if success then notify("God Gun Buff", "GOD MODE เปิดแล้ว! 💥", 2); updateGunBuffLabel(true)
        else notify("God Gun Buff", "ล้มเหลว ❌", 2) end
    end })

