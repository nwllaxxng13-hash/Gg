local function BE_isFriend(p)
    if p == LocalPlayer then return false end
    if friendCache[p] ~= nil then return friendCache[p] end
    local ok, isFriend = pcall(function()
        return LocalPlayer:IsFriendsWith(p.UserId)
    end)
    if ok then
        friendCache[p] = isFriend
        return isFriend
    end
    return false
end

