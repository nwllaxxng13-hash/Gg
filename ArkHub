-- =========================
local function getAimCenter()
    if aimingMark_enabled and aimingMark_pos then return aimingMark_pos end
    return fov_pos or viewportCenter()
end

local function GetSilentAimTarget()
    if not SilentAim_Enabled then return nil end
    local target = nil
    local bestDist = math.huge
    local currentFov = SilentAim_UseAimbotFov and fov_value or SilentAim_FovSize
    local center = getAimCenter()

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(SilentAim_TargetPart) then
            -- Team check
            if SilentAim_TeamCheck and v.Team == LocalPlayer.Team then continue end
            -- Friend check
            if SilentAim_FriendCheck and BE_isFriend(v) then continue end

            local hum = v.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local part = v.Character[SilentAim_TargetPart]
                local myHrp = getHRP()
                if not myHrp then continue end

                local dist3D = (part.Position - myHrp.Position).Magnitude
                if dist3D <= SilentAim_MaxDistance then
                    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                        if screenDist <= currentFov then
                            if screenDist < bestDist then
                                bestDist = screenDist
                                target = v.Character
                            end
                        end
                    end
                end
            end
        end
    end
    return target
end

