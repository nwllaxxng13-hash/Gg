local SilentAimConfig = {
    Enabled      = false,
    TargetPart   = "Head",
    MaxDistance  = 2000,
    TeamCheck    = false,
    FriendCheck  = true,
    UseAimbotFov = true,
    FovSize      = 150,
    ShotgunMode  = false,
    WallCheck    = true,   -- ตรวจสอบกำแพงก่อนล็อกเป้า
}

local sa_currentTarget    = nil
local sa_highlightInstance = nil

-- FOV helpers for Silent Aim
local function SA_getFovCenter()
    if SilentAimConfig.UseAimbotFov then return getAimCenter() end
    return fov_pos or viewportCenter()
end

local function SA_getFovSize()
    if SilentAimConfig.UseAimbotFov then return fov_value end
    return SilentAimConfig.FovSize
end

local function SA_onScreenAndInFov(worldPos)
    local sp, onScr = Camera:WorldToViewportPoint(worldPos)
    if not onScr then return false end
    local center = SA_getFovCenter()
    local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
    return d <= SA_getFovSize()
end

-- Wall check สำหรับ Silent Aim (raycast จากกล้องไปหา target part)
local sa_rayParams = RaycastParams.new()
sa_rayParams.FilterType  = Enum.RaycastFilterType.Exclude
sa_rayParams.IgnoreWater = true

local function SA_hasClearLOS(targetPart)
    if not (targetPart and targetPart.Parent) then return false end
    local camPos    = Camera.CFrame.Position
    local targetPos = targetPart.Position
    local dir       = (targetPos - camPos)
    local dist      = dir.Magnitude
    if dist <= 0 then return false end
    sa_rayParams.FilterDescendantsInstances = { LocalPlayer.Character }
    local result = Workspace:Raycast(camPos, dir.Unit * dist, sa_rayParams)
    if not result then return true end
    local inst = result.Instance
    if not inst then return true end
    -- ถือว่า clear ถ้า ray ชนส่วนของ character เป้าหมาย
    return inst:IsDescendantOf(targetPart.Parent)
end

local function SA_isEnemy(p)
    if p == LocalPlayer then return false end
    if SilentAimConfig.TeamCheck then
        local lt, tt = LocalPlayer.Team, p.Team
        if lt and tt and lt == tt then return false end
    end
    -- FriendCheck: ถ้าเปิด = ไม่ล็อกเพื่อนจริงๆ ในRoblox
    if SilentAimConfig.FriendCheck and BE_isFriend(p) then return false end
    return true
end

-- หาเป้าที่อยู่ใน FOV และใกล้ตัวเราที่สุด
local function SA_findTarget()
    local best, bestDist = nil, math.huge
    local myChar = LocalPlayer.Character; if not myChar then return nil end
    local myHead = myChar:FindFirstChild("Head") or myChar:FindFirstChild("HumanoidRootPart")
    if not myHead then return nil end

    for _, p in ipairs(Players:GetPlayers()) do
        if SA_isEnemy(p) and p.Character then
            local part = p.Character:FindFirstChild(SilentAimConfig.TargetPart)
                or p.Character:FindFirstChild("Head")
                or p.Character:FindFirstChild("HumanoidRootPart")
            if part and part:IsA("BasePart") then
                local hum = getHumFromChar(p.Character)
                if hum and hum.Health > 0 then
                    local dist = (part.Position - myHead.Position).Magnitude
                    if dist <= SilentAimConfig.MaxDistance and SA_onScreenAndInFov(part.Position) then
                        -- Wall check: ข้ามถ้าเปิดและไม่มี LOS
                        if SilentAimConfig.WallCheck and not SA_hasClearLOS(part) then continue end
                        if dist < bestDist then bestDist = dist; best = part end
                    end
                end
            end
        end
    end
    return best
end

-- Highlight เป้า Silent Aim (สีเหลือง แยกจาก ESP สีอื่น)
local function SA_updateHighlight(targetPart)
    if not targetPart or not targetPart.Parent then
        if sa_highlightInstance then pcall(function() sa_highlightInstance:Destroy() end); sa_highlightInstance = nil end
        return
    end
    local char = targetPart.Parent
    if not char or not char:IsDescendantOf(game) then
        if sa_highlightInstance then pcall(function() sa_highlightInstance:Destroy() end); sa_highlightInstance = nil end
        return
    end
    -- สร้างใหม่ถ้าไม่มี หรือ target เปลี่ยน
    if not sa_highlightInstance or not sa_highlightInstance.Parent or sa_highlightInstance.Adornee ~= char then
        if sa_highlightInstance then pcall(function() sa_highlightInstance:Destroy() end) end
        local hl = Instance.new("Highlight")
        hl.Adornee             = char
        hl.FillColor           = Color3.fromRGB(255, 220, 0)   -- เหลือง
        hl.FillTransparency    = 0.45
        hl.OutlineColor        = Color3.fromRGB(255, 255, 0)
        hl.OutlineTransparency = 0
        hl.Parent              = char
        sa_highlightInstance   = hl
    end
end

