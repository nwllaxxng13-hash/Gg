    icon.Name                   = "Icon"
    icon.Size                   = UDim2.fromScale(1, 1)
    icon.BackgroundTransparency = 1
    icon.Font                   = Enum.Font.GothamBold
    icon.TextSize               = 22
    icon.Text                   = "🔫"
    icon.TextColor3             = Color3.fromRGB(255, 255, 255)
    icon.ZIndex                 = 2
    icon.Parent                 = container

    -- Status label (ON/OFF)
    local statusL = Instance.new("TextLabel")
    statusL.Name                   = "Status"
    statusL.Size                   = UDim2.fromOffset(52, 14)
    statusL.AnchorPoint            = Vector2.new(0.5, 0)
    statusL.Position               = UDim2.new(0.5, 0, 1, 4)
    statusL.BackgroundTransparency = 1
    statusL.Font                   = Enum.Font.GothamBold
    statusL.TextSize               = 11
    statusL.Text                   = "OFF"
    statusL.TextColor3             = Color3.fromRGB(180, 180, 180)
    statusL.ZIndex                 = 2
    statusL.Parent                 = container

    -- Invisible hit area
    sg_btn = Instance.new("TextButton")
    sg_btn.Name                   = "HitArea"
    sg_btn.Size                   = UDim2.fromScale(1, 1)
    sg_btn.BackgroundTransparency = 1
    sg_btn.Text                   = ""
    sg_btn.AutoButtonColor        = false
    sg_btn.ZIndex                 = 3
    sg_btn.Parent                 = container

    local function updatePos()
        local p = SG_getPos()
        container.Position = UDim2.fromOffset(p.X, p.Y)
    end
    updatePos()

    -- Tween animation เมื่อกด toggle
    local function playToggleTween(on)
        local targetScale = on and 1.15 or 0.88
        local targetColor = on and Color3.fromRGB(0, 255, 80) or Color3.fromRGB(255, 60, 60)
        statusL.Text      = on and "ON" or "OFF"
        statusL.TextColor3 = targetColor

        local tweenIn = TweenService:Create(container,
            TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            { Size = UDim2.fromOffset(52 * targetScale, 52 * targetScale) }
        )
        tweenIn:Play()
        tweenIn.Completed:Connect(function()
            local tweenOut = TweenService:Create(container,
                TweenInfo.new(0.1, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                { Size = UDim2.fromOffset(52, 52) }
            )
            tweenOut:Play()
        end)
    end

    -- Click = toggle Shotgun Mode
    sg_btn.MouseButton1Click:Connect(function()
        SilentAimConfig.ShotgunMode = not SilentAimConfig.ShotgunMode
        playToggleTween(SilentAimConfig.ShotgunMode)
        notify("Shotgun Mode", SilentAimConfig.ShotgunMode and "ON 🔫" or "OFF", 1.0)
    end)

    -- Drag logic
    sg_btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch
        then
            sg_dragging = true
            sg_dragStart = Vector2.new(inp.Position.X, inp.Position.Y)
            sg_posStart  = SG_getPos()
            inp.Changed:Connect(function()
                if inp.UserInputState == Enum.UserInputState.End then
                    sg_dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if sg_dragging and (
            inp.UserInputType == Enum.UserInputType.MouseMovement or
            inp.UserInputType == Enum.UserInputType.Touch
        ) then
            local delta = Vector2.new(inp.Position.X, inp.Position.Y) - sg_dragStart
            local vp    = Camera.ViewportSize
            sg_pos = Vector2.new(
                clamp(sg_posStart.X + delta.X, 30, vp.X - 30),
                clamp(sg_posStart.Y + delta.Y, 30, vp.Y - 30)
            )
            container.Position = UDim2.fromOffset(sg_pos.X, sg_pos.Y)
        end
    end)

    -- RGB Heartbeat
    RunService.Heartbeat:Connect(function()
        if not sg_shotgunGui or not sg_shotgunGui.Parent then return end
        if not sg_rgbEnabled then return end
        local t   = now()
        local hue = (t * 0.5) % 1  -- รอบ 2 วิ
        local col = Color3.fromHSV(hue, 1, 1)
        local s   = container:FindFirstChild("RGBStroke")
        if s then s.Color = col end
    end)

    -- ซ่อนไว้ก่อน จนกว่า user เปิด
    sg_shotgunGui.Enabled = false
end

SG_createIcon()

