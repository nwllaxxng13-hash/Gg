-- SHOTGUN MODE ICON (Draggable HUD Button)
-- =========================
local TweenService      = game:GetService("TweenService")
local sg_shotgunGui     = nil
local sg_btn            = nil
local sg_dragging       = false
local sg_dragStart      = nil
