local function SA_findTarget()
    if SilentAimConfig.Version == "v2" then return SA_findTarget_v2() end
    return SA_findTarget_v1()
end

-- ─── Highlight (สีเหลือง v1 / ฟ้า v2) ──────────────────────
local function SA_updateHighlight(targetPart)
    -- กำจัด highlight เก่าถ้าหมดเป้า
    if not targetPart or not targetPart.Parent then
        if sa_highlightInstance then
            pcall(function() sa_highlightInstance:Destroy() end)
            sa_highlightInstance = nil
        end
        return
    end
    local char = targetPart.Parent
    if not char or not char:IsDescendantOf(game) then
        if sa_highlightInstance then
            pcall(function() sa_highlightInstance:Destroy() end)
            sa_highlightInstance = nil
        end
        return
    end
    local isV2       = SilentAimConfig.Version == "v2"
    local fillCol    = isV2 and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(255, 220, 0)
    local outlineCol = isV2 and Color3.fromRGB(0, 255, 200) or Color3.fromRGB(255, 255, 0)

    -- สร้างใหม่ถ้า Adornee เปลี่ยน หรือถูก destroy ไป
    if not sa_highlightInstance
        or not sa_highlightInstance.Parent
        or sa_highlightInstance.Adornee ~= char
    then
        if sa_highlightInstance then pcall(function() sa_highlightInstance:Destroy() end) end
        local hl = Instance.new("Highlight")
        hl.Adornee             = char
        hl.FillColor           = fillCol
        hl.FillTransparency    = 0.4
        hl.OutlineColor        = outlineCol
        hl.OutlineTransparency = 0
        hl.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent              = char
        sa_highlightInstance   = hl
    else
        sa_highlightInstance.FillColor    = fillCol
        sa_highlightInstance.OutlineColor = outlineCol
    end
end

-- ─── Velocity Predictor ─────────────────────────────────────
--  เก็บตำแหน่งล่าสุด 2 เฟรมเพื่อคำนวณ velocity → predict ตำแหน่งตอนกระสุนถึง
local sa_prevPos  = {}   -- [part] = {pos, t}
local sa_velocity = {}   -- [part] = Vector3

local function SA_updateVelocity(part)
    if not part or not part.Parent then
        sa_prevPos[part]  = nil
        sa_velocity[part] = nil
        return
    end
    local curPos = part.Position
    local curT   = now()
    local prev   = sa_prevPos[part]
    if prev then
        local dt = curT - prev.t
        if dt > 0 and dt < 0.2 then
            sa_velocity[part] = (curPos - prev.pos) / dt
        end
    end
    sa_prevPos[part] = { pos = curPos, t = curT }
end

local function SA_predictPos(part, travelTime)
    local vel = sa_velocity[part]
    if not vel or not part or not part.Parent then
        return part and part.Position or Vector3.new()
    end
    -- predict ด้วย velocity × เวลาเดินทาง + damping
    return part.Position + vel * travelTime * 0.85
end

-- ─── หา Muzzle Attachment ───────────────────────────────────
local MUZZLE_NAMES = { "Muzzle", "FirePoint", "BarrelPoint", "Barrel", "MuzzlePoint", "ShootPoint" }

local function SA_findMuzzle(args)
    -- 1. หา Attachment จาก Args โดยตรง (ส่วนใหญ่ game ส่งมา)
    for _, v in pairs(args) do
        if typeof(v) == "Instance" and v:IsA("Attachment") then
            return v.WorldPosition
        end
    end
    -- 2. หาจาก Args ที่เป็น BasePart
    for _, v in pairs(args) do
        if typeof(v) == "Instance" and v:IsA("BasePart") then
            -- ลองหา Attachment ชื่อ muzzle ใน part นั้น
            for _, name in ipairs(MUZZLE_NAMES) do
                local att = v:FindFirstChild(name)
                if att and att:IsA("Attachment") then return att.WorldPosition end
            end
            return v.Position
        end
    end
    -- 3. หาจาก Tool ที่กำลังถืออยู่
    local char = LocalPlayer.Character
    if char then
        local tool = char:FindFirstChildOfClass("Tool")
        if tool then
            for _, name in ipairs(MUZZLE_NAMES) do
                local att = tool:FindFirstChild(name, true)
                if att and att:IsA("Attachment") then return att.WorldPosition end
            end
        end
        -- fallback = Head
        local head = char:FindFirstChild("Head")
        if head then return head.Position end
    end
    return Camera.CFrame.Position
end

-- ─── คำนวณ bullet travel time ───────────────────────────────
local function SA_estimateTravelTime(muzzlePos, targetPos)
    -- bullet speed ทั่วไปใน FE Gun Kit ~1800–2500 studs/s
    -- ใช้ 2000 เป็น default (แม่นพอ)
    local dist = (targetPos - muzzlePos).Magnitude
    return dist / 2000
end

-- ─── RenderStepped: update target + velocity ─────────────────
--  ใช้ RenderStepped (ทุกเฟรมก่อน render) แทน Heartbeat
--  ทำให้ sa_currentTarget ใหม่ล่าสุดเสมอตอน hookmetamethod ทำงาน
RunService.RenderStepped:Connect(function()
    if not SilentAimConfig.Enabled then
        if sa_currentTarget then
            sa_currentTarget = nil
            SA_updateHighlight(nil)
        end
        return
    end
    local newTarget = SA_findTarget()
    -- อัป velocity ของเป้าที่ lock อยู่
    if newTarget then SA_updateVelocity(newTarget) end
    -- ล้าง velocity ของเป้าเก่าที่เปลี่ยนไป
    if sa_currentTarget ~= newTarget and sa_currentTarget then
        sa_velocity[sa_currentTarget] = nil
        sa_prevPos[sa_currentTarget]  = nil
    end
    sa_currentTarget = newTarget
    SA_updateHighlight(sa_currentTarget)
end)

-- ─── hookmetamethod — PRECISION OVERRIDE ────────────────────
--  หลักการสำคัญ:
--  1. ตอน fire → re-find target ทันที (ไม่ใช้ cached ที่อาจเก่า)
--  2. หา MuzzlePos จาก Attachment จริง
--  3. Predict ตำแหน่ง target เมื่อกระสุนถึง
--  4. Override ทุก field ที่เป็น Vector3/direction ใน Args
--  5. Override key ที่ชื่อ Origin, Direction, HitPos ถ้ามี
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()

    if not SilentAimConfig.Enabled then
        return OldNamecall(self, ...)
    end
    if Method ~= "FireServer" then
        return OldNamecall(self, ...)
    end
    -- รับ VisualizeBullet และ RemoteEvent ชื่ออื่นที่อาจเป็นระบบยิง
    local name = self.Name
    local isGunEvent = name == "VisualizeBullet"
        or name == "Fire" or name == "shoot"
        or name == "Shoot" or name == "BulletFired"
        or name == "OnFire" or name == "FireBullet"

    if not isGunEvent then
        return OldNamecall(self, ...)
    end

    local Args = { ... }

    -- ── หาเป้า: ใช้ current ก่อน ถ้าไม่มีให้ find ทันที ──
    local Target = sa_currentTarget
    if not Target or not Target.Parent then
        Target = SA_findTarget()
        sa_currentTarget = Target
    end

    if not Target or not Target.Parent then
        return OldNamecall(self, ...)
    end

    -- ── หา MuzzlePos ──
    local MuzzlePos = SA_findMuzzle(Args)

    -- ── Predict ตำแหน่งเป้าตอนกระสุนถึง ──
    local rawTargetPos  = Target.Position
    local travelTime    = SA_estimateTravelTime(MuzzlePos, rawTargetPos)
    local predictedPos  = SA_predictPos(Target, travelTime)

    -- ── คำนวณ direction แม่น ──
    local dirVec = predictedPos - MuzzlePos
    if dirVec.Magnitude < 0.001 then dirVec = Camera.CFrame.LookVector end
    local baseDir = dirVec.Unit

    local spreadVal = GunBuffConfig.Settings.Spread or 20

    -- ── Override Args ──
    for _, arg in pairs(Args) do
        if typeof(arg) == "table" then
            for k, v in pairs(arg) do
                -- Override ทุก Vector3 ที่ดูเหมือน direction (magnitude ≈ 1 หรือเป็นศูนย์)
                if typeof(v) == "Vector3" then
                    local mag = v.Magnitude
                    -- direction vector มักมี magnitude ≤ 1.01
                    -- position vector มักมี magnitude > 10
                    if mag <= 1.01 then
                        if SilentAimConfig.ShotgunMode then
                            local spreadRad = math.rad(spreadVal * 0.5)
                            local rx = (math.random() - 0.5) * 2 * spreadRad
                            local ry = (math.random() - 0.5) * 2 * spreadRad
                            local cone = CFrame.new(Vector3.new(), baseDir) * CFrame.Angles(rx, ry, 0)
                            arg[k] = cone.LookVector
                        else
                            arg[k] = baseDir
                        end
                    -- override HitPos/position vectors ที่น่าจะเป็น target position
                    elseif mag > 10 then
                        local kStr = tostring(k):lower()
                        if kStr:find("hit") or kStr:find("end") or kStr:find("target") then
                            arg[k] = predictedPos
                        end
                    end
                end

                -- Override key ชื่อต่างๆ ที่รู้จัก
                local kStr = type(k) == "string" and k:lower() or ""
                if kStr == "spread" or kStr == "accuracy" then
                    arg[k] = SilentAimConfig.ShotgunMode and spreadVal or 0
                elseif kStr == "recoil" then
                    arg[k] = 0
                elseif kStr == "direction" or kStr == "dir" then
                    arg[k] = baseDir
                elseif kStr == "origin" or kStr == "startpos" or kStr == "muzzlepos" then
                    arg[k] = MuzzlePos
                end
            end
        end

        -- Override Vector3 โดยตรงใน Args (บาง game ส่ง direction เป็น arg ตรงๆ ไม่ใส่ table)
        if typeof(arg) == "Vector3" then
            -- ไม่ override ตรงๆ เพราะ {...} เป็น read-only แต่เราจัดการผ่าน table แล้ว
        end
    end

    return OldNamecall(self, unpack(Args))
end)

