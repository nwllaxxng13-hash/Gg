-- SILENT AIM SYSTEM
-- =========================
local SilentAimConfig = {
    Enabled      = false,
    Version      = "v1",
    TargetPart   = "Head",
    MaxDistance  = 2000,
    TeamCheck    = false,
    FriendCheck  = true,
    UseAimbotFov = true,
    FovSize      = 150,
    ShotgunMode  = false,
    WallCheck    = true,
}

local sa_currentTarget     = nil
local sa_highlightInstance = nil

-- ─── FOV helpers ────────────────────────────────────────────
local function SA_getFovCenter()
    if SilentAimConfig.UseAimbotFov then return getAimCenter() end
    return fov_pos or viewportCenter()
end
local function SA_getFovSize()
    if SilentAimConfig.UseAimbotFov then return fov_value end
    return SilentAimConfig.FovSize
end
local function SA_onScreenAndInFov(worldPos)
    local sp, onScr = Camera:WorldToViewportPoint(worldPos)
    if not onScr then return false end
    return (Vector2.new(sp.X, sp.Y) - SA_getFovCenter()).Magnitude <= SA_getFovSize()
end
local function SA_screenDist(worldPos)
    local sp, onScr = Camera:WorldToViewportPoint(worldPos)
    if not onScr then return math.huge end
    return (Vector2.new(sp.X, sp.Y) - SA_getFovCenter()).Magnitude
end

-- ─── Wall-check ─────────────────────────────────────────────
local sa_rayParams = RaycastParams.new()
sa_rayParams.FilterType  = Enum.RaycastFilterType.Exclude
sa_rayParams.IgnoreWater = true

local function SA_hasClearLOS(targetPart)
    if not (targetPart and targetPart.Parent) then return false end
    local camPos = Camera.CFrame.Position
    local dir    = targetPart.Position - camPos
    local dist   = dir.Magnitude
    if dist <= 0 then return false end
    sa_rayParams.FilterDescendantsInstances = { LocalPlayer.Character }
    local result = Workspace:Raycast(camPos, dir.Unit * dist, sa_rayParams)
    if not result then return true end
    return result.Instance and result.Instance:IsDescendantOf(targetPart.Parent)
end

-- ─── Enemy filter ───────────────────────────────────────────
local function SA_isEnemy(p)
    if p == LocalPlayer then return false end
    if SilentAimConfig.TeamCheck then
        local lt, tt = LocalPlayer.Team, p.Team
        if lt and tt and lt == tt then return false end
    end
    if SilentAimConfig.FriendCheck and BE_isFriend(p) then return false end
    return true
end

-- ─── V1: ล็อกด้วย world-distance (reliable) ─────────────────
local function SA_findTarget_v1()
    local best, bestDist = nil, math.huge
    local myChar = LocalPlayer.Character; if not myChar then return nil end
    local myRef  = myChar:FindFirstChild("Head") or myChar:FindFirstChild("HumanoidRootPart")
    if not myRef then return nil end
    for _, p in ipairs(getCachedPlayers()) do
        if SA_isEnemy(p) and p.Character then
            local part = p.Character:FindFirstChild(SilentAimConfig.TargetPart)
                or p.Character:FindFirstChild("Head")
                or p.Character:FindFirstChild("HumanoidRootPart")
            if part and part:IsA("BasePart") then
                local hum = getHumFromChar(p.Character)
                if hum and hum.Health > 0 then
                    local dist = (part.Position - myRef.Position).Magnitude
                    if dist <= SilentAimConfig.MaxDistance and SA_onScreenAndInFov(part.Position) then
                        if SilentAimConfig.WallCheck and not SA_hasClearLOS(part) then continue end
                        if dist < bestDist then bestDist = dist; best = part end
                    end
                end
            end
        end
    end
    return best
end

-- ─── V2: ล็อกด้วย screen-distance + sticky lock ─────────────
--  หลักการ:
--  1. เลือกเป้าที่ใกล้ศูนย์ FOV ที่สุดบนจอ (แม่นกว่า world-dist มาก)
--  2. Sticky lock - ล็อกเป้าค้างไว้ MIN_HOLD_TIME วิ ก่อนสลับ
--     ป้องกัน highlight กระพริบและกระสุนหลุดเป้า
--  3. สลับเป้าใหม่เฉพาะเมื่อ: เป้าตาย / ออกนอก FOV / เกิน hold time
--     และเป้าใหม่ใกล้ศูนย์มากกว่าเดิม > SWITCH_THRESHOLD px
local SA_V2_MIN_HOLD_TIME   = 0.25  -- วิ ก่อนจะยอมสลับเป้า
local SA_V2_SWITCH_THRESHOLD = 25   -- px — ใกล้กว่าเดิมเท่านี้ถึงสลับ
local sa_v2_lockedTarget    = nil
local sa_v2_lockedAt        = 0
local sa_v2_lockFrames      = 0

local function SA_v2_isTargetStillValid(part)
    if not part or not part.Parent then return false end
    local hum = getHumFromChar(part.Parent)
    if not hum or hum.Health <= 0 then return false end
    if not SA_onScreenAndInFov(part.Position) then return false end
    if SilentAimConfig.WallCheck and not SA_hasClearLOS(part) then return false end
    return true
end

local function SA_findTarget_v2()
    -- ถ้าเป้าเดิมยังใช้ได้และยังไม่ครบ hold time → คืนเป้าเดิมเลย
    local t = now()
    if sa_v2_lockedTarget and SA_v2_isTargetStillValid(sa_v2_lockedTarget) then
        if t - sa_v2_lockedAt < SA_V2_MIN_HOLD_TIME then
            return sa_v2_lockedTarget
        end
    end

    -- หา candidates ทั้งหมดใน FOV
    local best, bestSDist = nil, math.huge
    for _, p in ipairs(getCachedPlayers()) do
        if SA_isEnemy(p) and p.Character then
            local part = p.Character:FindFirstChild(SilentAimConfig.TargetPart)
                or p.Character:FindFirstChild("Head")
                or p.Character:FindFirstChild("HumanoidRootPart")
            if part and part:IsA("BasePart") then
                local hum = getHumFromChar(p.Character)
                if hum and hum.Health > 0 then
                    local myChar = LocalPlayer.Character
                    local myRef  = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Head"))
                    local wDist  = myRef and (part.Position - myRef.Position).Magnitude or math.huge
                    if wDist <= SilentAimConfig.MaxDistance and SA_onScreenAndInFov(part.Position) then
                        if SilentAimConfig.WallCheck and not SA_hasClearLOS(part) then continue end
                        local sd = SA_screenDist(part.Position)
                        if sd < bestSDist then bestSDist = sd; best = part end
                    end
                end
            end
        end
    end

    if not best then
        sa_v2_lockedTarget = nil
        return nil
    end

    -- ถ้ายังไม่มีเป้า หรือเป้าเดิมหมดอายุ → lock เป้าใหม่ทันที
    if not sa_v2_lockedTarget or not SA_v2_isTargetStillValid(sa_v2_lockedTarget) then
        sa_v2_lockedTarget = best
        sa_v2_lockedAt     = t
        return best
    end

    -- ถ้าเป้าใหม่ใกล้ศูนย์กว่าเดิมมากพอ → สลับ
    local curSDist = SA_screenDist(sa_v2_lockedTarget.Position)
    if bestSDist < curSDist - SA_V2_SWITCH_THRESHOLD then
        sa_v2_lockedTarget = best
        sa_v2_lockedAt     = t
        return best
    end

    -- ยังคืนเป้าเดิม
    return sa_v2_lockedTarget
end

