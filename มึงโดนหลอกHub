local function BE_isFriend(p)
    if p == LocalPlayer then return false end
    if friendCache[p] ~= nil then return friendCache[p] end
    local ok, isFriend = pcall(function() return LocalPlayer:IsFriendsWith(p.UserId) end)
    if ok then friendCache[p] = isFriend; return isFriend end
    return false
end

local function BE_applyOne(p)
    local char = p and p.Character; if not char then return end
    local hum  = getHumFromChar(char); if not hum or hum.Health <= 0 then return end
    if not BE_isFriend(p) then return end
    local hrp = getHRPFromChar(char); if not hrp then return end
    local st = buddyStates[p]
    if not st then st = { hrp = hrp, lastTextAt = 0 }; buddyStates[p] = st
    else st.hrp = hrp end
    local buddyColor = Color3.fromRGB(100, 255, 100)
    if not st.highlight then st.highlight = BE_createHighlight(char, buddyColor) end
    if not st.esp or not st.esp.Parent then
        st.esp, st.name, st.hp, st.team = BE_createBillboard(hrp, p)
    end
    local t = now()
    if t - (st.lastTextAt or 0) >= 0.4 then
        pcall(function()
            st.hp.Text   = "HP: " .. math.floor(hum.Health)
            st.team.Text = "Team: " .. (p.Team and p.Team.Name or "None")
        end)
        st.lastTextAt = t
    end
end

