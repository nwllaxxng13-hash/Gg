                end
            end
        end
        
        if autoDribbleEnabled then
            local _, HRP, _ = getCharSafe()
            if HRP then
                for _, p in pairs(P:GetPlayers()) do
                    if isOpponent(p) then
                        local eChar = p.Character; local eHRP = eChar and eChar:FindFirstChild("HumanoidRootPart"); local eHum = eChar and eChar:FindFirstChild("Humanoid")
                        if eHRP and eHum then
