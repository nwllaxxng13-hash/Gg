local function v2_clampToViewport(p, r)
    local vp = Camera.ViewportSize
    return Vector2.new(
        clamp(p.X, r, math.max(r, vp.X - r)),
        clamp(p.Y, r, math.max(r, vp.Y - r))
    )
end
local function viewportCenter()
    local vp = Camera.ViewportSize
    return Vector2.new(vp.X / 2, vp.Y / 2)
end

