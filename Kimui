-- Get all tools from player
local function getAllTools()
    local tools = {}
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                table.insert(tools, item.Name)
            end
        end
    end
    
    if character then
        for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Tool") then
                if not table.find(tools, item.Name) then
                    table.insert(tools, item.Name)
                end
            end
        end
    end
    
    table.sort(tools)
    return tools
end

-- Execute Gun Buff
local function executeGunBuff()
    if not GunBuffConfig.SelectedGun then
        notify("Gun Buff", "กรุณาเลือกปืนก่อน!", 2)
        return false
    end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    local gun = nil
    
    if backpack then
        gun = backpack:FindFirstChild(GunBuffConfig.SelectedGun)
    end
    if not gun and character then
        gun = character:FindFirstChild(GunBuffConfig.SelectedGun)
    end
    
    if not gun then
        notify("Gun Buff", "ไม่พบปืน: " .. GunBuffConfig.SelectedGun, 2)
        updateGunBuffLabel(false)
        return false
    end
    
    local settingModule = gun:FindFirstChild("Setting")
    if not settingModule then
        notify("Gun Buff", "ไม่พบ Setting module", 2)
        updateGunBuffLabel(false)
        return false
    end
    
    local mainSetting = settingModule:FindFirstChild("1")
    if not mainSetting then
        notify("Gun Buff", "ไม่พบ Setting/1", 2)
        updateGunBuffLabel(false)
        return false
    end
    
    local success = pcall(function()
        local h = require(mainSetting)
        for key, value in pairs(GunBuffConfig.Settings) do
            if h[key] ~= nil then
                h[key] = value
            end
        end
    end)
    
    if success then
        notify("Gun Buff", "บัฟปืนสำเร็จ! ✅", 1.5)
        updateGunBuffLabel(true)
        return true
    else
        notify("Gun Buff", "บัฟปืนล้มเหลว ❌", 2)
        updateGunBuffLabel(false)
        return false
    end
end

