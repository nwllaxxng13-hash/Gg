getgenv().zone = false
TabMain:Button({
    Title = "วาร์ปไปโซนปลอดภัย (Safe Zone)",
    Desc = "กดเพื่อวาร์ปไปพื้นที่ปลอดภัย และกดอีกครั้งเพื่อกลับมาที่เดิม",
