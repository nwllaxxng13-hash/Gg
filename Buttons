-- [[ Tab: มองทะลุ (ESP) ]]
local playerESPUpdate
TabESP:Toggle({
    Title = "มองทะลุผู้เล่น (Players ESP)",
    Value = Options.PlayerESP,
    Callback = function(value)
        Options.PlayerESP = value
        if value then
            for _, player in pairs(players:GetPlayers()) do
                if player ~= plr then
                    createPlayerESP(player)
                end
            end
            if not playerESPUpdate then
                playerESPUpdate = RunService.Heartbeat:Connect(function()
                    for _, player in pairs(players:GetPlayers()) do
                        if player ~= plr and player.Character then
                            local folder = player.Character:FindFirstChild("PlayerESP_Folder")
                            if folder then
                                local bgui = folder:FindFirstChild("NameESP")
                                if bgui then
                                    local text = bgui:FindFirstChild("TextLabel")
                                    local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
                                    if text and humanoid then
                                        text.Text = player.Name .. " : " .. tostring(math.floor(humanoid.Health))
                                        if player:GetAttribute("Ghost") and text.TextColor3 ~= Color3.fromRGB(0, 255, 255) then
                                            text.TextColor3 = Color3.fromRGB(0, 255, 255)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
            end
        else
            clearPlayerESP()
            if playerESPUpdate then
                playerESPUpdate:Disconnect()
                playerESPUpdate = nil
            end
        end
    end
})

TabESP:Toggle({
    Title = "มองทะลุไอเทม (Items ESP)",
    Value = Options.ItemESP,
    Callback = function(value)
        Options.ItemESP = value
        if value then
            for _, item in pairs(workspace:GetChildren()) do
                createESP(item)
            end
        else
            clearESP()
        end
    end
})

workspace.ChildAdded:Connect(function(obj)
    if Options.ItemESP then
        createESP(obj)
    end
end)

-- [[ Tab: อื่นๆ (Misc) ]]
local infJump
local infJumpDebounce = false

TabMisc:Toggle({
    Title = "กระโดดไม่จำกัด (Inf Jump)",
    Value = Options.InfJump,
    Callback = function(value)
        Options.InfJump = value
        if value then
            infJumpDebounce = false
            infJump = UserInputService.JumpRequest:Connect(function()
                if not infJumpDebounce and plr.Character then
                    local hum = plr.Character:FindFirstChildWhichIsA("Humanoid")
                    if hum then
                        infJumpDebounce = true
                        hum:ChangeState(Enum.HumanoidStateType.Jumping)
                        task.wait()
                        infJumpDebounce = false
                    end
                end
            end)
        else
            if infJump then infJump:Disconnect() end
            infJumpDebounce = false
        end
    end
})

TabMisc:Toggle({
    Title = "ตีรัว (ปิดคูลดาวน์การตี)",
    Value = Options.RmvHitCooldown,
    Callback = function(value)
        Options.RmvHitCooldown = value
    end
})

-- Handle HitCooldown via loop for safety across respawns
task.spawn(function()
    while task.wait(0.1) do
        if Options.RmvHitCooldown then
            local char = plr.Character
            local hum = char and char:FindFirstChildWhichIsA("Humanoid")
            if hum and hum:GetAttribute("HitCooldown") ~= false then
                hum:SetAttribute("HitCooldown", false)
            end
        end
    end
end)

TabMisc:Button({
    Title = "สตามิน่าไม่จำกัด (Inf Stamina)",
    Icon = "solar:running-bold",
    Callback = function()
        local char = plr.Character
        local hum = char and char:FindFirstChildWhichIsA("Humanoid")
        if hum then
            hum:SetAttribute("MaxStamina", math.huge)
            hum:SetAttribute("Stamina", math.huge)
