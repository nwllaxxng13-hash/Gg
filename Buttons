-- [[ Tab: หน้าหลัก (Main) ]]
TabMain:Section({ Title = "การเคลื่อนที่ & ตัวละคร" })

local tpwalk
TabMain:Toggle({
    Title = "วิ่งเร็ว (Speed Boost)",
    Value = Options.SpeedBoost,
    Callback = function(value)
        Options.SpeedBoost = value
        if value then
            tpwalk = RunService.Heartbeat:Connect(function(delta)
                local char = plr.Character
                local hum = char and char:FindFirstChildWhichIsA("Humanoid")
                if char and hum and hum.Parent and hum.MoveDirection.Magnitude > 0 then
                    char:TranslateBy(hum.MoveDirection * 2.3 * delta * 10)
                end
            end)
        else
            if tpwalk then tpwalk:Disconnect() end
        end
    end
})

local Noclipping
TabMain:Toggle({
    Title = "เดินทะลุกำแพง (Noclip)",
    Value = Options.Noclip,
    Callback = function(value)
        Options.Noclip = value
        if value then
            Noclipping = RunService.Stepped:Connect(function()
                if plr.Character ~= nil then
                    for _, child in pairs(plr.Character:GetDescendants()) do
                        if child:IsA("BasePart") and child.CanCollide == true then
                            child.CanCollide = false
                        end
                    end
                end
            end)
        else
            if Noclipping then Noclipping:Disconnect() end
        end
    end
})

TabMain:Toggle({
    Title = "ปิดดาเมจตกจากที่สูง (Remove Fall Damage)",
    Value = Options.RmvFallDamage,
    Callback = function(value)
        Options.RmvFallDamage = value
        local char = plr.Character
        if char then
            local falldamage = char:FindFirstChild("FallDamage")
            if falldamage then 
                falldamage.Enabled = not value 
            end
        end
    end
})

TabMain:Section({ Title = "จัดการไอเทม" })

TabMain:Toggle({
