-- ==========================================
-- AUTO HOP LOGIC (V1 - 3 MIN)
-- ==========================================
local function ServerHop()
    local req = (type(syn) == "table" and syn.request) or request or http_request
    if req then
        local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
        local success, result = pcall(function()
            return HttpService:JSONDecode(req({Url = url, Method = "GET"}).Body)
        end)
        if success and result and result.data then
            local servers = {}
            for _, v in ipairs(result.data) do
                if v.playing < v.maxPlayers and v.id ~= game.JobId then
                    table.insert(servers, v.id)
                end
            end
            if #servers > 0 then
                ResetAllState()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], L)
                return
            end
        end
    end
    ResetAllState()
    TeleportService:Teleport(game.PlaceId, L)
end

-- ==========================================
-- AUTO HOP V2 LOGIC (2 MIN - Smart)
-- ==========================================
local function ServerHopV2Smart()
    local req = (type(syn) == "table" and syn.request) or request or http_request
    if req then
        local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
        local success, result = pcall(function()
            return HttpService:JSONDecode(req({Url = url, Method = "GET"}).Body)
        end)
        if success and result and result.data then
            local qualifyingServers = {}
            local anyServers = {}
            
            for _, v in ipairs(result.data) do
                if v.id ~= game.JobId and v.playing < v.maxPlayers then
                    table.insert(anyServers, v)
                    -- Servers with 4 players or lower
                    if v.playing <= 4 then
                        table.insert(qualifyingServers, v)
                    end
                end
            end
            
            local targetServer = nil
            
            -- Priority: 4 players or lower
            if #qualifyingServers > 0 then
                targetServer = qualifyingServers[math.random(1, #qualifyingServers)]
            -- Fallback: any server with space
            elseif #anyServers > 0 then
                targetServer = anyServers[math.random(1, #anyServers)]
            end
            
            if targetServer then
                ResetAllState()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer.id, L)
                return
            end
        end
    end
    ResetAllState()
    TeleportService:Teleport(game.PlaceId, L)
end

