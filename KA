-- ==========================================
-- ANTI-CHEAT BYPASS: SAFE WARP (TWEEN)
-- ==========================================
local function SafeWarp(targetCFrame)
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local dist = (myHRP.Position - targetCFrame.Position).Magnitude

    -- หากอยู่ไกลเกิน 15 Studs จะใช้การพุ่ง (Tween) เพื่อหลบ Anti-Speed/Teleport
    if dist > 15 then
        local safeSpeed = 250 -- ปรับแต่งความเร็วให้พอดี ไม่เกินลิมิตเกม
        local timeToTravel = dist / safeSpeed
        
        -- ลบ Tween เก่าทิ้งก่อนเพื่อกันบั๊กกระตุก
        if CurrentTween then CurrentTween:Cancel() end
        
        local tweenInfo = TweenInfo.new(timeToTravel, Enum.EasingStyle.Linear)
        CurrentTween = TweenService:Create(myHRP, tweenInfo, {CFrame = targetCFrame})
        CurrentTween:Play()
    else
        -- ถ้าระยะใกล้มากแล้ว ให้แตะติดแบบเนียนๆ
        if CurrentTween then CurrentTween:Cancel(); CurrentTween = nil end
        myHRP.CFrame = targetCFrame
    end
end

