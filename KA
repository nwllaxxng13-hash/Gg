local function GetPlayerLevel()
    local levelNum = 0
    pcall(function()
        if L:FindFirstChild("leaderstats") then
            local lvl = L.leaderstats:FindFirstChild("Level") or L.leaderstats:FindFirstChild("Lv")
            if lvl then levelNum = tonumber(lvl.Value) end
        end
    end)
    if levelNum and levelNum > 0 then return levelNum end
    
    pcall(function()
        local lvl = L:FindFirstChild("Level") or L:FindFirstChild("PlayerLevel")
        if lvl then levelNum = tonumber(lvl.Value) end
    end)
    if levelNum and levelNum > 0 then return levelNum end

    pcall(function()
        local liveChar = workspace:FindFirstChild("Live") and workspace.Live:FindFirstChild(L.Name)
        if liveChar then
            local overhead = liveChar:FindFirstChild("Overhead")
            if overhead and overhead:FindFirstChild("Frame") and overhead.Frame:FindFirstChild("Level") and overhead.Frame.Level:FindFirstChild("TextLabel") then
                local num = string.match(overhead.Frame.Level.TextLabel.Text, "%d+")
                if num then levelNum = tonumber(num) end
            end
        end
    end)
    return levelNum or 0
end

