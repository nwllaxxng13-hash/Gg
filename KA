-- ==========================================
-- TARGETING LOGIC (STRICT PLAYER ONLY)
-- ==========================================
local function IsTargetValid(target)
    if not target or not target.Parent then return false end
    if target == L then return false end
    if not Players:FindFirstChild(target.Name) then return false end
    
    local char = target.Character
    if not char or not char.Parent then return false end
    
    local hum = char:FindFirstChild("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if not hum or not hrp or not hrp.Parent then return false end
    if hum.Health <= 0 then return false end
    
    return true
end

local function GetNearestPlayer()
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP or not myHRP.Parent then return nil end

    local nearest = nil
    local minDist = math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= L and IsTargetValid(p) then
            local enemyHRP = p.Character.HumanoidRootPart
            if enemyHRP and enemyHRP.Parent then
                local dist = (enemyHRP.Position - myHRP.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = p
                end
            end
        end
    end
    return nearest
end

local function GetAllValidPlayers()
    local validTargets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= L and IsTargetValid(p) then
            table.insert(validTargets, p)
        end
    end
    return validTargets
end

-- V4: Get valid players excluding killed targets
