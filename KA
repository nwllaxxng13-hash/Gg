-- ==========================================
-- AIR STUCK DETECTION & FIX
-- ==========================================
local function CheckAndFixAirStuck()
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local hum = myChar and myChar:FindFirstChild("Humanoid")
    
    if not myHRP or not myHRP.Parent or not hum then return end
    
    local currentPos = myHRP.Position
    
    if LastValidPosition then
        local distance = (currentPos - LastValidPosition).Magnitude
        
        if distance < 0.5 and hum.Health > 0 then
            AirStuckCounter = AirStuckCounter + 1
        else
            AirStuckCounter = 0
        end
    end
    
    LastValidPosition = currentPos
    
    if AirStuckCounter > 5 then
        hum.PlatformStand = false
        myHRP.CFrame = myHRP.CFrame + Vector3.new(0, 10, 0)
        myHRP.AssemblyLinearVelocity = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.2)
        AirStuckCounter = 0
        LastValidPosition = nil
        CurrentTarget = nil
    end
end

