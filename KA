local ConfigFile = "FoxKaijuConfig.json"

local function SaveConfig()
    pcall(function()
        if writefile then
            local data = {
                V1 = FarmingV1Enabled,
                V2 = FarmingV2Enabled,
                V3 = FarmingV3Enabled,
                V4 = FarmingV4Enabled,
                Hop = AutoHopEnabled,
