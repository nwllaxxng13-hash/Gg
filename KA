task.spawn(function()
    while true do
        if FarmingV4Enabled and InitialSpawnDone and (tick() - LastHopTime) > 2 then
            local myChar = L.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            
            if myHRP and myHRP.Parent then
                pcall(function()
                    CombatRemote:FireServer("UseSkill", "Attack1")
                    CombatRemote:FireServer("UseSkill", "Attack2")
                    CombatRemote:FireServer("UseSkill", "Attack3")
                end)

                -- Check if current target is still valid (alive and not killed)
                if not IsTargetValid(CurrentTarget) or KilledTargets[CurrentTarget.Name] then
                    CurrentTarget = nil
                end
                
                -- Find new target if needed
                if not CurrentTarget then
                    CurrentTarget = GetNearestPlayerV4()
                end

                -- If all players are killed, hop server
                local validTargets = GetAllValidPlayersV4()
                if #validTargets == 0 then
                    ServerHopV2Smart()
                    task.wait(5)
                end

                if CurrentTarget then
                    local targetChar = CurrentTarget.Character
                    if targetChar and targetChar.Parent then
                        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
                        local targetHum = targetChar:FindFirstChild("Humanoid")
                        if targetHRP and targetHRP.Parent then
                            -- Mark target as killed if health is 0
                            if targetHum and targetHum.Health <= 0 then
                                KilledTargets[CurrentTarget.Name] = true
                                CurrentTarget = nil
                            else
                                myHRP.CFrame = targetHRP.CFrame
                                myHRP.AssemblyLinearVelocity = Vector3.zero
                                myHRP.AssemblyAngularVelocity = Vector3.zero
                            end
                        else
                            CurrentTarget = nil
                        end
                    else
                        CurrentTarget = nil
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)
