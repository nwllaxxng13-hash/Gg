local function IsTargetValid(target)
    if not target or not target.Parent or target == L or not Players:FindFirstChild(target.Name) then return false end
    local char = target.Character
    if not char or not char.Parent then return false end
    local hum = char:FindFirstChild("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp or not hrp.Parent or hum.Health <= 0 then return false end
    return true
end

local function GetNearestPlayer()
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local nearest, minDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= L and IsTargetValid(p) then
            local dist = (p.Character.HumanoidRootPart.Position - myHRP.Position).Magnitude
            if dist < minDist then minDist = dist; nearest = p end
        end
    end
    return nearest
end

local function GetAllValidPlayers()
    local validTargets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= L and IsTargetValid(p) then table.insert(validTargets, p) end
    end
    return validTargets
end

local function GetNearestPlayerV4()
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local nearest, minDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= L and IsTargetValid(p) and not KilledTargets[p.Name] then
            local dist = (p.Character.HumanoidRootPart.Position - myHRP.Position).Magnitude
            if dist < minDist then minDist = dist; nearest = p end
        end
    end
    return nearest
end

