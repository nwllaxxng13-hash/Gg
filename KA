    local hrp = myChar:FindFirstChild("HumanoidRootPart")
    
    if hum and hrp then
        hum.PlatformStand = false
        hrp.CanCollide = true
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 5, 0)
        hrp.AssemblyLinearVelocity = Vector3.zero
