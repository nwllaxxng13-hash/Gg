local function GetPlayerLevel()
    local levelNum = 0
    -- Layer 1: Check standard leaderstats (Most reliable if available)
    pcall(function()
        if L:FindFirstChild("leaderstats") then
            local lvl = L.leaderstats:FindFirstChild("Level") or L.leaderstats:FindFirstChild("Lv")
            if lvl then levelNum = tonumber(lvl.Value) end
        end
    end)
    if levelNum and levelNum > 0 then return levelNum end
    
    -- Layer 2: Check direct Player object value
    pcall(function()
        local lvl = L:FindFirstChild("Level") or L:FindFirstChild("PlayerLevel")
        if lvl then levelNum = tonumber(lvl.Value) end
    end)
    if levelNum and levelNum > 0 then return levelNum end

    -- Layer 3: Fallback to Overhead GUI tracking
    pcall(function()
        local liveChar = workspace:FindFirstChild("Live") and workspace.Live:FindFirstChild(L.Name)
        if liveChar then
            local overhead = liveChar:FindFirstChild("Overhead")
            if overhead and overhead:FindFirstChild("Frame") and overhead.Frame:FindFirstChild("Level") and overhead.Frame.Level:FindFirstChild("TextLabel") then
                local text = overhead.Frame.Level.TextLabel.Text
                local num = string.match(text, "%d+")
                if num then
                    levelNum = tonumber(num)
                end
            end
        end
    end)
    return levelNum or 0
end

local function CheckAndFixAirStuck()
    local myChar = L.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local hum = myChar and myChar:FindFirstChild("Humanoid")
    
    if not myHRP or not myHRP.Parent or not hum then return end
    local currentPos = myHRP.Position
    
    if LastValidPosition then
        local distance = (currentPos - LastValidPosition).Magnitude
        if distance < 0.5 and hum.Health > 0 then
            AirStuckCounter = AirStuckCounter + 1
        else
            AirStuckCounter = 0
        end
    end
    
    LastValidPosition = currentPos
    
    if AirStuckCounter > 5 then
        hum.PlatformStand = false
        myHRP.CFrame = myHRP.CFrame + Vector3.new(0, 10, 0)
        myHRP.AssemblyLinearVelocity = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.2)
        AirStuckCounter = 0
        LastValidPosition = nil
        CurrentTarget = nil
    end
end

local function InitializeCharacter()
    local myChar = L.Character
    if not myChar then return end
    
    local hum = myChar:FindFirstChild("Humanoid")
    local hrp = myChar:FindFirstChild("HumanoidRootPart")
    
    if hum and hrp then
        hum.PlatformStand = false
        hrp.CanCollide = true
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 5, 0)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
        task.wait(0.5)
        hum.PlatformStand = false
    end
    
    InitialSpawnDone = true
    LastValidPosition = nil
    AirStuckCounter = 0
end

