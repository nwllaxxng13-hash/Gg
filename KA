local ConfigFile = "FoxKaijuConfig.json"

local function SaveConfig()
    pcall(function()
        if writefile then
            local data = {
                V1 = FarmingV1Enabled, V2 = FarmingV2Enabled, V3 = FarmingV3Enabled, V4 = FarmingV4Enabled,
                Hop = AutoHopEnabled, HopV2 = AutoHopV2Enabled, KaijuName = KaijuName,
                AdminHopCount = AdminHopCount, AutoLockBeam = AutoLockBeamEnabled,
                SelectedSkills = SelectedSkills, Noclip = NoclipEnabled,
                AutoSpaceG = AutoSpaceGodzilla, KStage = KaiTanStage
            }
            writefile(ConfigFile, HttpService:JSONEncode(data))
        end
    end)
end

local function LoadConfig()
    pcall(function()
        if readfile and isfile and isfile(ConfigFile) then
            local decoded = HttpService:JSONDecode(readfile(ConfigFile))
            if type(decoded) == "table" then
                FarmingV1Enabled = decoded.V1 or false
                FarmingV2Enabled = decoded.V2 or false
                FarmingV3Enabled = decoded.V3 or false
                FarmingV4Enabled = decoded.V4 or false
                AutoHopEnabled = decoded.Hop or false
                AutoHopV2Enabled = decoded.HopV2 or false
                KaijuName = decoded.KaijuName or "Biollante"
                AdminHopCount = decoded.AdminHopCount or 0
                AutoLockBeamEnabled = decoded.AutoLockBeam or false
                NoclipEnabled = decoded.Noclip or false
                AutoSpaceGodzilla = decoded.AutoSpaceG or false
                KaiTanStage = decoded.KStage or 1
                if decoded.SelectedSkills then
                    for skill, val in pairs(decoded.SelectedSkills) do SelectedSkills[skill] = val end
                end
            end
        end
    end)
end
