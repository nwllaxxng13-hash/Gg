                        KilledTargets[CurrentTarget.Name] = true
                        CurrentTarget = nil
                    elseif not IsTargetValid(CurrentTarget) then
                        CurrentTarget = nil
                    end
                end
                
                local otherPlayersCount = 0
                local killedCount = 0
                for _, p in pairs(Players:GetPlayers()) do
