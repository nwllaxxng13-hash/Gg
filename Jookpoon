-- ฟังก์ชัน Warp
task.spawn(function()
    while true do
        if _G.WarpEnabled then
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                -- ไปจุดที่ 1
                char.HumanoidRootPart.CFrame = CFrame.new(Pos1)
                task.wait(2) -- ปรับเวลาพักรอตามต้องการ
                
                -- ไปจุดที่ 2 (ตรวจสอบอีกรอบเผื่อปิดกลางคัน)
                if _G.WarpEnabled then
                    char.HumanoidRootPart.CFrame = CFrame.new(Pos2)
                    task.wait(2)
                end
            end
        end
        task.wait(0.1)
    end
end)

-- ฟังก์ชัน Fire ProximityPrompts รอบตัว
task.spawn(function()
    while true do
        if _G.PromptEnabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    -- เช็คระยะห่าง (ถ้ารัศมีเกิน 20 หน่วยจะไม่ทำงาน เพื่อความเนียน)
                    local player = game.Players.LocalPlayer
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (v.Parent.Position - player.Character.HumanoidRootPart.Position).Magnitude
                        if dist < 20 then 
                            fireproximityprompt(v)
                        end
                    end
                end
            end
        end
        task.wait(0.2) -- ปรับความเร็วในการเช็ค Prompt
    end
end)

-- Logic ปุ่มกด
WarpToggle.MouseButton1Click:Connect(function()
    _G.WarpEnabled = not _G.WarpEnabled
    WarpToggle.Text = _G.WarpEnabled and "Loop Warp: ON" or "Loop Warp: OFF"
    WarpToggle.BackgroundColor3 = _G.WarpEnabled and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(200, 0, 0)
end)

PromptToggle.MouseButton1Click:Connect(function()
    _G.PromptEnabled = not _G.PromptEnabled
    PromptToggle.Text = _G.PromptEnabled and "Auto Prompt: ON" or "Auto Prompt: OFF"
    PromptToggle.BackgroundColor3 = _G.PromptEnabled and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(200, 0, 0)
end)
