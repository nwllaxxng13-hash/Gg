local function CreateToggle(name, text, pos)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Parent = MainFrame
    btn.Position = pos
    btn.Size = UDim2.new(0, 150, 0, 50)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    return btn
end

local WarpBtn = CreateToggle("WarpBtn", "Loop Warp", UDim2.new(0, 10, 0, 50))
local FireBtn = CreateToggle("FireBtn", "Auto Fire", UDim2.new(0, 10, 0, 110))

-- [[ 3. ระบบการทำงาน (Logic) ]] --

-- ฟังก์ชัน Fire Prompt
local function FireAllNearby()
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                local dist = (v.Parent.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < 30 then
                    fireproximityprompt(v)
                end
            end
        end
    end
end

-- ลูป Warp สลับจุด
task.spawn(function()
    while task.wait() do
        if Config.WarpEnabled then
            local char = lp.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = CFrame.new(Config.Pos1)
                task.wait(Config.WarpDelay)
                if not Config.WarpEnabled then break end
                char.HumanoidRootPart.CFrame = CFrame.new(Config.Pos2)
                task.wait(Config.WarpDelay)
            end
        end
    end
end)

-- ลูป Auto Fire (รัวจัด)
task.spawn(function()
    while task.wait(0.1) do
        if Config.AutoFire then
            FireAllNearby()
        end
    end
end)

-- [[ 4. ระบบ Toggle ]] --
WarpBtn.MouseButton1Click:Connect(function()
    Config.WarpEnabled = not Config.WarpEnabled
    WarpBtn.Text = "Loop Warp: " .. (Config.WarpEnabled and "ON" or "OFF")
    WarpBtn.BackgroundColor3 = Config.WarpEnabled and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(45, 45, 45)
end)

FireBtn.MouseButton1Click:Connect(function()
    Config.AutoFire = not Config.AutoFire
    FireBtn.Text = "Auto Fire: " .. (Config.AutoFire and "ON" or "OFF")
    FireBtn.BackgroundColor3 = Config.AutoFire and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(45, 45, 45)
end)
