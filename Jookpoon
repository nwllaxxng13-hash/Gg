-- [[ จกปูน V.2 FIXED + INSTANT HOLD ]] --

local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local lp = Players.LocalPlayer

-- ลบ UI เก่า
if CoreGui:FindFirstChild("CementFarmV2_Fixed") then
    CoreGui:FindFirstChild("CementFarmV2_Fixed"):Destroy()
end

-- ตั้งค่า
local Config = {
    Pos1 = Vector3.new(1329.260, 1150.113, -4859.753),
    Pos2 = Vector3.new(865.900, 1129.000, -5981.842),
    WarpEnabled = false,
    AutoFire = false,
    WarpDelay = 0.01, -- ปรับความเร็วการสลับจุด
    HoldTime = 0 -- 0 คือกดทันที (Instant)
}

-- [[ 1. ระบบแก้ไข ProximityPrompt ให้กดไวขึ้น ]] --
local function ModifyPrompts(obj)
    if obj:IsA("ProximityPrompt") then
        obj.HoldDuration = Config.HoldTime
        -- ปรับระยะการกดให้ไกลขึ้นนิดหน่อยเพื่อความเสถียร
        obj.MaxActivationDistance = 30 
    end
end

-- ตรวจจับ Prompt ที่มีอยู่แล้วและที่กำลังจะเกิดใหม่
for _, v in pairs(workspace:GetDescendants()) do ModifyPrompts(v) end
workspace.DescendantAdded:Connect(ModifyPrompts)

-- [[ 2. สร้าง GUI แบบสมบูรณ์ ]] --
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CementFarmV2_Fixed"
