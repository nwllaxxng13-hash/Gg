-- [[ ระบบการทำงาน ]] --

-- ฟังก์ชัน Fire Prompt แบบเร็วพิเศษ
local function ExecuteFire()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local distance = (v.Parent.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                if distance < 25 then -- ระยะจก
                    fireproximityprompt(v)
                end
            end
        end
    end
end

-- ลูปการทำงาน Warp
task.spawn(function()
    while task.wait() do
        if Config.WarpEnabled then
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                -- ไปจุดที่ 1
                lp.Character.HumanoidRootPart.CFrame = CFrame.new(Config.Pos1)
                task.wait(Config.WarpSpeed)
                
                -- ไปจุดที่ 2
                if Config.WarpEnabled then
                    lp.Character.HumanoidRootPart.CFrame = CFrame.new(Config.Pos2)
                    task.wait(Config.WarpSpeed)
                end
            end
        end
    end
end)

-- ลูปการทำงาน Auto Fire (รัวมาก)
task.spawn(function()
    while task.wait(0.05) do
        if Config.AutoFire then
            ExecuteFire()
        end
    end
end)

-- [[ ระบบ Toggle ]] --
WarpBtn.MouseButton1Click:Connect(function()
