-- [[ จกปูน V.2 - EXTREME SPEED VERSION ]] --

-- ตั้งค่าตำแหน่ง
local Pos1 = Vector3.new(1329.260, 1150.113, -4859.753)
local Pos2 = Vector3.new(865.900, 1129.000, -5981.842)

-- สถานะการทำงาน
local Settings = {
    WarpEnabled = false,
    AutoFire = false,
    WarpDelay = 0.01, -- ปรับความเร็วการวาร์ป (วินาที)
    FireRange = 30 -- ระยะการกด
}

-- [[ ระบบ GUI ]] --
local CoreGui = game:GetService("CoreGui")
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CementFarmV2"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 170, 0, 200)
MainFrame.Position = UDim2.new(0.5, -85, 0.4, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = ToolFormat.UDim(0, 10)
UICorner.Parent = MainFrame

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Text = "จกปูน V.2 [FAST]"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 18
Title.Font = Enum.Font.SourceSansBold
Title.BackgroundTransparency = 1
Title.Parent = MainFrame

-- ฟังก์ชันสร้างปุ่ม
local function CreateButton(name, text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(0, 150, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    btn.Parent = MainFrame
    
    local corner = Instance.new("UICorner")
    corner.Parent = btn
    return btn
end

local WarpBtn = CreateButton("WarpBtn", "Warp Loop: OFF", UDim2.new(0, 10, 0, 60), Color3.fromRGB(150, 0, 0))
local FireBtn = CreateButton("FireBtn", "Auto Fire: OFF", UDim2.new(0, 10, 0, 120), Color3.fromRGB(150, 0, 0))

-- [[ ฟังก์ชันการทำงาน ]] --

-- 1. ลูป Warp แบบไว
task.spawn(function()
    while task.wait() do
        if Settings.WarpEnabled then
            local p = game.Players.LocalPlayer
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                -- จุดที่ 1
                p.Character.HumanoidRootPart.CFrame = CFrame.new(Pos1)
                task.wait(Settings.WarpDelay)
                
                -- จุดที่ 2
                if Settings.WarpEnabled then
                    p.Character.HumanoidRootPart.CFrame = CFrame.new(Pos2)
                    task.wait(Settings.WarpDelay)
                end
            end
        end
    end
end)

-- 2. ลูป Fire Prompt แบบแก้บั๊ก (ใช้การเช็ครัศมีรอบตัว)
task.spawn(function()
    while task.wait(0.05) do -- เช็ครัวๆ ทุก 0.05 วินาที
        if Settings.AutoFire then
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        local distance = (v.Parent.Position - char.HumanoidRootPart.Position).Magnitude
                        if distance <= Settings.FireRange then
                            fireproximityprompt(v)
                        end
                    end
                end
            end
        end
    end
end)

-- [[ ระบบ Toggle ]] --
WarpBtn.MouseButton1Click:Connect(function()
    Settings.WarpEnabled = not Settings.WarpEnabled
    WarpBtn.Text = Settings.WarpEnabled and "Warp Loop: ON" or "Warp Loop: OFF"
    WarpBtn.BackgroundColor3 = Settings.WarpEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)

FireBtn.MouseButton1Click:Connect(function()
    Settings.AutoFire = not Settings.AutoFire
    FireBtn.Text = Settings.AutoFire and "Auto Fire: ON" or "Auto Fire: OFF"
    FireBtn.BackgroundColor3 = Settings.AutoFire and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
end)
