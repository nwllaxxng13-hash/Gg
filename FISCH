TabSettings:Dropdown({
	Title = "เลือกธีม",
	Value = ThemeName,
	Values = Themes,
	Callback = function(value)
		ThemeName = value
		Window:SetTitle("Ark Hub - Fisch (" .. ThemeName .. ")")
		WindUI:SetTheme(ThemeName)
		WindUI:Notify({
			Title = "เปลี่ยนธีม",
			Content = "ใช้ธีม " .. ThemeName .. " แล้ว",
		})
		
		if Remote then
			local PRNumber = WindUI.Themes[ThemeName]
				and WindUI.Themes[ThemeName].Metadata
				and WindUI.Themes[ThemeName].Metadata.PullRequest
			
			if PRNumber then
				Window:SetAuthor("กำลังโหลด...")
				if not CachedPRData[PRNumber] then
					local Success, Data = pcall(function()
						return Remote:InvokeServer("Footagesus", "WindUI", PRNumber)
					end)
					
					if Success and Data and Data.html_url then
						CachedPRData[PRNumber] = Data
						Window:SetAuthor(
							"โดย " .. Data.user.login
						)
					end
				else
					local Data = CachedPRData[PRNumber]
					Window:SetAuthor(
						"โดย " .. Data.user.login
					)
				end
			else
				Window:SetAuthor("By Ark")
			end
		end
	end,
})

