-- [[ Smart NPC Scanner ]]
local CachedNPCs = {}
task.spawn(function()
    while task.wait(3) do
        local newCache = {}
        local allObjects = workspace:GetDescendants()
        for i, obj in ipairs(allObjects) do
            if i % 100 == 0 then RunService.Heartbeat:Wait() end
            if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                local hrp = obj:FindFirstChild("HumanoidRootPart")
                if hum and hrp and hum.Health > 0 then
                    if not Players:GetPlayerFromCharacter(obj) then
                        table.insert(newCache, obj)
                    end
                end
            end
        end
        CachedNPCs = newCache
    end
end)

local function GetClosestTarget()
    local closestDistance = Features.TargetDistance
    local closestTarget = nil
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
    local potentialTargets = {}
    
    if Features.TargetMode == "Players" or Features.TargetMode == "Both" then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                table.insert(potentialTargets, player.Character)
            end
        end
    end
    if Features.TargetMode == "NPCs" or Features.TargetMode == "Both" then
        for _, npc in pairs(CachedNPCs) do
            if npc and npc.Parent and npc:FindFirstChild("HumanoidRootPart") and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                table.insert(potentialTargets, npc)
            end
        end
    end
    for _, target in pairs(potentialTargets) do
        local targetPos = target.HumanoidRootPart.Position
        local distance = (targetPos - myPos).Magnitude
        if distance <= closestDistance then
            closestDistance = distance
            closestTarget = target
        end
    end
    return closestTarget
end

-- [[ Highlight Loop ]]
local LastTarget = nil
task.spawn(function()
    while task.wait(0.2) do 
        if Features.HighlightTarget then
            local target = GetClosestTarget()
            if target ~= LastTarget then
                LastTarget = target
                TargetHighlight.Adornee = target
                TargetHighlight.Enabled = target ~= nil
            end
        elseif TargetHighlight.Enabled then
            TargetHighlight.Enabled = false
            TargetHighlight.Adornee = nil
            LastTarget = nil
        end
    end
end)

-- [[ Dynamic Circular Dash Function ]]
local function CircularDash(targetHRP)
    local myChar = LocalPlayer.Character
    local myHRP = myChar.HumanoidRootPart
    local myHum = myChar:FindFirstChild("Humanoid")
    
    if not myHRP or not targetHRP or not myHum then return end
    
    local dashDuration = Features.DashSpeed 
    local radius = Features.DashDistance 
    
    local targetPos = targetHRP.Position
    -- หาเวกเตอร์ด้านหลังของเป้าหมายแบบ 2D (ไม่สนความสูง)
    local flatTargetLook = Vector3.new(targetHRP.CFrame.LookVector.X, 0, targetHRP.CFrame.LookVector.Z).Unit
    local backDir = -flatTargetLook
    local finalPos = targetPos + (backDir * radius)
    
    -- หาเวกเตอร์ปัจจุบันของเราเทียบกับเป้าหมาย
    local vecToMe = myHRP.Position - targetPos
    local flatVecToMe = Vector3.new(vecToMe.X, 0, vecToMe.Z)
    
    if flatVecToMe.Magnitude < 0.1 then
        flatVecToMe = backDir
    else
        flatVecToMe = flatVecToMe.Unit
    end
    
    -- คำนวณมุมที่เหลืออยู่เพื่อไปถึงด้านหลัง
    local dot = math.clamp(flatVecToMe:Dot(backDir), -1, 1)
    local angleToBack = math.acos(dot)
    
    -- เช็คทิศทางที่สั้นที่สุด (ซ้าย หรือ ขวา)
    local crossY = flatVecToMe:Cross(backDir).Y
    local direction = crossY >= 0 and 1 or -1 -- 1 = ซ้าย, -1 = ขวา
    
    -- ถ้าเราอยู่ตรงหน้าเป้าหมายเป๊ะๆ (มากกว่า 170 องศา) ให้ใช้ค่าจาก Dropdown เป็นตัวตัดสินว่าจะฉีกทางไหน
    if angleToBack > math.rad(170) then
        direction = Features.DashSide == "Left" and 1 or -1
    end
    
    -- ล็อคกล้อง
    local cameraLockConn
    if Features.LockAimDash then
        cameraLockConn = RunService.RenderStepped:Connect(function()
            if targetHRP and targetHRP.Parent then
                local currentCF = Camera.CFrame
                local targetCF = CFrame.lookAt(currentCF.Position, targetHRP.Position)
                Camera.CFrame = currentCF:Lerp(targetCF, 0.25)
            end
        end)
    end
    
    -- ถ้าอยู่ด้านหลังอยู่แล้ว (องศาเหลือน้อยกว่า 15 องศา) ไม่ต้องอ้อม พุ่งจัดระเบียบตรงๆ เลย
    if angleToBack < math.rad(15) then
        TweenService:Create(myHRP, TweenInfo.new(dashDuration * 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            CFrame = CFrame.lookAt(finalPos, targetPos)
        }):Play()
        
        task.delay(dashDuration * 0.5, function()
            if cameraLockConn then cameraLockConn:Disconnect() end
        end)
        return
    end
    
    -- ถ้าต้องพุ่งอ้อม ให้เล่น Animation ตามทิศทางที่ไป
    local animator = myHum:FindFirstChild("Animator") or myHum
    local track
    if direction == 1 then
        track = animator:LoadAnimation(AnimLeft)
    else
        track = animator:LoadAnimation(AnimRight)
    end
    if track then track:Play() end
    
    -- เริ่มลูปการพุ่งอ้อม
    local startRelPos = flatVecToMe * radius
    local startTime = tick()
    local dashConn
    
    dashConn = RunService.Heartbeat:Connect(function()
        local elapsed = tick() - startTime
        local alpha = math.clamp(elapsed / dashDuration, 0, 1)
        
        if not targetHRP or not targetHRP.Parent or not myHRP or not myHRP.Parent or alpha >= 1 then
            if dashConn then dashConn:Disconnect() end
            if cameraLockConn then cameraLockConn:Disconnect() end
            
            -- จบการทำงาน หันหน้าเข้าหาเป้าหมาย
            if myHRP and targetHRP and targetHRP.Parent then
                myHRP.CFrame = CFrame.lookAt(targetPos + (backDir * radius), targetPos)
            end
            return
        end
        
        -- หมุนองศาเท่าที่จำเป็นต้องอ้อมเท่านั้น (ไม่ใช่ครึ่งวงกลมเต็ม)
        local currentAngle = alpha * angleToBack * direction
        local rotationCF = CFrame.Angles(0, currentAngle, 0)
        local currentRelPos = rotationCF:VectorToWorldSpace(startRelPos)
        
        local newPosition = targetPos + currentRelPos
        myHRP.CFrame = CFrame.lookAt(newPosition, targetPos)
    end)
end

-- [[ Hooking Remote ]]
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    
    if not checkcaller() and method == "FireServer" and self.Name == "Activated" and self.Parent and self.Parent.Name == "RE" and self.Parent.Parent and self.Parent.Parent.Name == "DivergentFistService" then
        
        if (Features.AutoBlackFlashV1 or Features.AutoBlackFlashV2) and not IsFiring then
            IsFiring = true 
            task.spawn(function()
                task.wait(0.33) 
                local moveArgs = {LocalPlayer.Character:WaitForChild("Moveset"):WaitForChild("Divergent Fist")}
                self:FireServer(unpack(moveArgs))

                if Features.AutoBlackFlashV2 then
                    local target = GetClosestTarget()
                    if target and target:FindFirstChild("HumanoidRootPart") then
                        CircularDash(target.HumanoidRootPart)
                    end
                end
                task.wait(0.1) 
                IsFiring = false 
            end)
        end
    end
    return OldNamecall(self, ...)
end)

